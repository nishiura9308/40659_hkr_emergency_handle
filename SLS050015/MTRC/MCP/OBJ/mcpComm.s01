asci_0_recv_ir:
; 284.	
; 285.	
; 286.	/************************************************************************
; 287.	
; 288.	        Function name   << asci_0_recv_ir >>
; 289.	                                        受信割り込み処理
; 290.	        Syntax                  asci_0_recv_ir( char data, char status );
; 291.	        Argument                none
; 292.	        Author                  TOA Corporation  K.Honda
; 293.	        Revision                a00 2000/06/27
; 294.	
; 295.	*************************************************************************/
; 296.	void asci_0_recv_ir( char data, char status )
; 297.	{
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	BC
	PUSH	DE
; 298.	/*.     ---------------------　処理詳細説明  ----------------------------       */
; 299.	/*  フェーズ毎に受信データを取り込む                                                                    */
; 300.	/*. ------------------------------------------------------------------  */
; 301.	status=0;
	LD	(IX-2),0
; 302.	                if( data == DLE ){              /* ＤＬＥ受信 */
	LD	A,E
	CP	16
	JR	NZ,?0043
?0042:
; 303.	                        recvdle = 1;
	LD	A,1
	LD	(recvdle),A
; 304.	                        return;
; 305.	                }
	JP	?0068
?0043:
; 306.	                if( data == STX ){              /* ＳＴＸ受信 */
	LD	B,(IX-4)
	DEC	B
	DEC	B
	JR	NZ,?0045
?0044:
; 307.	                        if( recvdle ){          /*  DLE+STX */
	LD	A,(recvdle)
	OR	A
	JR	Z,?0047
?0046:
; 308.	                                recvdle = 0;
	XOR	A
	LD	(recvdle),A
; 309.	                                recvphase = COMM_WAIT_ETX;
	LD	A,1
	LD	(recvphase),A
; 310.	                                recvlen = 0;
	XOR	A
	LD	(recvlen),A
; 311.	                                recvbcc = 0;
	XOR	A
	LD	(recvbcc),A
?0047:
; 312.	                        }
; 313.	                        return;
; 314.	                }
	JP	?0068
?0045:
; 315.	        
; 316.	                switch( recvphase ){
	LD	A,(recvphase)
	CP	0
	JR	NZ,?0050
?0049:
; 317.	                case COMM_WAIT_STX:             /* ＳＴＸ待ち */
; 318.	                        break;
	JP	?0048
?0050:
	CP	1
	JR	NZ,?0058
; 319.	        
; 320.	                case COMM_WAIT_ETX:
; 321.	                        if( recvdle ){          /* ＤＬＥ処理 */
	LD	A,(recvdle)
	OR	A
	JR	Z,?0052
?0051:
; 322.	                                recvdle = 0;
	XOR	A
	LD	(recvdle),A
; 323.	                                if( data == ETX ){              /* ＥＴＸの受信 ( DLE+ETX ) */
	LD	A,(IX-4)
	CP	3
	JR	NZ,?0054
?0053:
; 324.	                                        recvbcc ^= data;
	LD	A,(recvbcc)
	XOR	(IX-4)
	LD	(recvbcc),A
; 325.	                                        recvphase = COMM_WAIT_BCC;
	LD	A,2
	LD	(recvphase),A
; 326.	                                        break;
	JP	?0048
?0054:
; 327.	                                }
; 328.	                                data = data - 0x40;     /* データのＤＬＥ拡張 */
	LD	A,(IX-4)
	ADD	A,192
	LD	(IX-4),A
?0052:
; 329.	                        }
; 330.	        
; 331.	                        if( recvlen<sizeof(recvbuff) ){
	LD	A,(recvlen)
	CP	64
	JR	NC,?0056
?0055:
; 332.	                                recvbcc ^= data;
	LD	A,(recvbcc)
	XOR	(IX-4)
	LD	(recvbcc),A
; 333.	                                recvbuff[recvlen++] = data;
	LD	HL,recvlen
	LD	C,(HL)
	INC	(HL)
	LD	B,0
	LD	HL,recvbuff
	ADD	HL,BC
	LD	B,(IX-4)
	LD	(HL),B
; 334.	                        }
; 335.	                        else {
	JR	?0057
?0056:
; 336.	                                recvphase = COMM_WAIT_STX;
	XOR	A
	LD	(recvphase),A
?0057:
; 337.	                        }
; 338.	                        break;
	JR	?0048
?0058:
	CP	2
	JR	NZ,?0048
; 339.	        
; 340.	                case COMM_WAIT_BCC:
; 341.	                        if( recvdle ){          /* ＤＬＥ処理 */
	LD	A,(recvdle)
	OR	A
	JR	Z,?0060
?0059:
; 342.	                                recvdle = 0;
	XOR	A
	LD	(recvdle),A
; 343.	                                data = data - 0x40;     /* データのＤＬＥ拡張 */
	LD	A,(IX-4)
	ADD	A,192
	LD	(IX-4),A
?0060:
; 344.	                        }
; 345.	                        recvbcc ^= data;
	LD	A,(recvbcc)
	XOR	(IX-4)
	LD	(recvbcc),A
; 346.	                        if( recvbcc==0 ){
	OR	A
	JR	NZ,?0062
?0061:
; 347.	                                if( recvlen==recvbuff[0]+1 ){
	LD	BC,(recvbuff)
	LD	B,0
	INC	BC
	LD	DE,(recvlen)
	LD	D,0
	LD	L,C
	LD	H,B
	AND	A
	SBC	HL,DE
	JR	NZ,?0064
?0063:
; 348.	                                        asci_0_rx_disable();
	CALL	asci_0_rx_disable
; 349.	                                        __enable();
	CALL	__enable
; 350.	                                        if( mcpReceive( &recvbuff[1], recvlen-1 ) ){
	LD	A,(recvlen)
	ADD	A,255
	LD	C,A
	LD	DE,recvbuff+1
	CALL	mcpReceive
	OR	A
	JR	Z,?0066
?0065:
; 351.	                                                mcpSend();
	CALL	mcpSend
; 352.	                                        }
; 353.	                                        else {
	JR	?0067
?0066:
; 354.	                                                __disable();
	CALL	__disable
; 355.	                                                asci_0_rx_enable();
	CALL	asci_0_rx_enable
?0067:
?0064:
?0062:
; 356.	                                        }
; 357.	                                }
; 358.	                        }
; 359.	                        recvphase = COMM_WAIT_STX;
	XOR	A
	LD	(recvphase),A
; 360.	                        break;
	JR	?0048
?0048:
; 361.	                }
; 362.	}
?0068:
	LD	SP,IX
	POP	IX
	RET
; 363.	
	RSEG	UDATA0
