	LD	HL,21
	LD	C,(IX-8)
	LD	B,(IX-7)
	ADD	HL,BC
	POP	BC
	LDIR
; 238.	                                memcpy( &sw_blink, &p->display[2+4*6], 2 );                     /* SW-Blink */
	LD	BC,2
	PUSH	BC
	LD	DE,sw_blink
	LD	HL,45
	LD	C,(IX-8)
	LD	B,(IX-7)
	ADD	HL,BC
	POP	BC
	LDIR
; 239.	                                memcpy( matrix_blink, &p->display[2+4*6+2], 4 );        /* Matrix Blink */
	LD	BC,4
	PUSH	BC
