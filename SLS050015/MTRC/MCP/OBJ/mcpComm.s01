	INC	HL
	LD	A,(HL)
	AND	0
	LD	(HL),A
; 244.	                                sw_led = (sw_led & SWLED_HL) | (leddata & ~SWLED_HL);   /* SW-LED */
	LD	HL,(sw_led)
	LD	A,L
	AND	32
	LD	C,A
	LD	A,H
	AND	0
	LD	B,A
	LD	A,(IX-6)
	AND	223
	LD	E,A
	LD	A,(IX-5)
	AND	255
	LD	D,A
	LD	A,C
	OR	E
	LD	L,A
	LD	A,B
	OR	D
	LD	H,A
	LD	(sw_led),HL
; 245.	                                memset( matrix_led, 0, 4*6 );                   /* Matrix-LED */
	LD	BC,24
	LD	DE,matrix_led
	LD	HL,0
	CALL	?MEMSET_L11
; 246.	                                sw_blink = 0;
	LD	HL,0
	LD	(sw_blink),HL
; 247.	                                memset( matrix_blink, 0, 4 );   /* Matrix Blink */
	LD	BC,4
	LD	DE,matrix_blink
	LD	HL,0
	CALL	?MEMSET_L11
?0032:
?0029:
; 248.	                        }
; 249.	                }
; 250.	
; 251.	                if( p->kind=='S' ){             /* 車両番号の登録 */
	LD	L,(IX-8)
	LD	H,(IX-7)
	INC	HL
	INC	HL
	LD	A,(HL)
	CP	83
	JP	NZ,?0034
?0033:
; 252.	                        /*
; 253.	                                address
; 254.	                                        -------------- +1 -------------  ------------- +0 -------------
; 255.	                 64180 Side     b15 b14 b13 b12 b11 b10  b9  b8  b7  b6  b5  b4  b3  b2  b1  b0
; 256.	                        H8 Side  b7  b6  b5  b4  b3  b2  b1  b0 b15 b14 b13 b12 b11 b10  b9  b8
; 257.	                                        -- Car No.--    ----- AD -----   -----Car No.--  -- Car No.----
; 258.	                                            3210                             BA98             7654
; 259.	
; 260.	                                carNo
; 261.	                                        -------------- +1 -------------  ------------- +0 -------------
; 262.	                 64180 Side     b15 b14 b13 b12 b11 b10  b9  b8  b7  b6  b5  b4  b3  b2  b1  b0
; 263.	                        H8 Side  b7  b6  b5  b4  b3  b2  b1  b0 b15 b14 b13 b12 b11 b10  b9  b8
; 264.	                                        -- Car No.--    -- Car No.  --                  -- Car No.----
; 265.	                                            7654           3210                              BA98
; 266.	                        */
; 267.	                        address &= 0x0F00;
	LD	HL,address
	LD	A,(HL)
	AND	0
	LD	(HL),A
	INC	HL
	LD	A,(HL)
	AND	15
	LD	(HL),A
; 268.	                        address |= ((p->carno & 0x00F00)<<4)  & 0x0F000;        /* car No. 3210 */
	LD	HL,4
	LD	C,(IX-8)
	LD	B,(IX-7)
	ADD	HL,BC
	LD	A,(HL)
	AND	0
	LD	E,A
	INC	HL
	LD	A,(HL)
	AND	15
	LD	D,A
	EX	DE,HL
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	LD	A,L
	AND	0
	LD	E,A
	LD	A,H
	AND	240
	LD	D,A
	LD	HL,address
	LD	A,(HL)
	OR	E
	LD	(HL),A
	INC	HL
	LD	A,(HL)
	OR	D
	LD	(HL),A
; 269.	                        address |= ((p->carno & 0x0F000)>>12) & 0x0000F;        /* car No. 7654 */
	LD	HL,4
	ADD	HL,BC
	LD	A,(HL)
	AND	0
	LD	E,A
	INC	HL
	LD	A,(HL)
	AND	240
	LD	D,A
	LD	B,12
	CALL	?US_RSH_L02
	LD	A,E
	AND	15
	LD	C,A
	LD	A,D
	AND	0
	LD	B,A
	LD	HL,address
	LD	A,(HL)
	OR	C
	LD	(HL),A
	INC	HL
	LD	A,(HL)
	OR	B
	LD	(HL),A
; 270.	                        address |= ((p->carno & 0x0000F)<<4)  & 0x000F0;        /* car No. BA98 */
	LD	HL,4
	LD	C,(IX-8)
	LD	B,(IX-7)
	ADD	HL,BC
	LD	A,(HL)
	AND	15
	LD	C,A
	INC	HL
	LD	A,(HL)
	AND	0
	LD	B,A
	LD	L,C
	LD	H,B
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	ADD	HL,HL
	LD	A,L
	AND	240
	LD	C,A
	LD	A,H
	AND	0
	LD	B,A
	LD	HL,address
	LD	A,(HL)
	OR	C
	LD	(HL),A
	INC	HL
	LD	A,(HL)
	OR	B
	LD	(HL),A
?0034:
; 271.	                }
