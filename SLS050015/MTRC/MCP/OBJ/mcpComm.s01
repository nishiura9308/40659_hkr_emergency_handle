?0031:
; 242.	                                memcpy( &leddata, p->display, 2 );
	LD	BC,2
	PUSH	BC
	LD	HL,4
	ADD	HL,SP
	LD	E,L
	LD	D,H
	LD	HL,19
	LD	C,(IX-8)
	LD	B,(IX-7)
	ADD	HL,BC
	POP	BC
	LDIR
; 243.	                                leddata &= SWLED_CABCAB;
	LD	HL,2
	ADD	HL,SP
