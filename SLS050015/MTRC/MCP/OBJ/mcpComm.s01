	NAME	mcpcomm(16)
	RSEG	CODE(0)
	RSEG	UDATA0(0)
	EXTERN	__disable
	EXTERN	__enable
	PUBLIC	address
	PUBLIC	asci_0_recv_ir
	EXTERN	asci_0_rx_disable
	EXTERN	asci_0_rx_enable
	PUBLIC	asci_0_send_ir
