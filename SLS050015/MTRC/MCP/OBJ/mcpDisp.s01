; 1146.	void mcpBlinkCount( void )
; 1147.	{
; 1148.	                if( blinkCount<25 ){            /*ō_ōöā^āCā~āōāO*/
	LD	A,(blinkCount)
	CP	25
	JR	NC,?0057
?0056:
; 1149.	                        blinkPositionCheck = 0x0ff;
	LD	A,255
	LD	(blinkPositionCheck),A
; 1150.	                }
; 1151.	                else {                                          /*Å┴ōöā^āCā~āōāO*/
	JR	?0058
?0057:
; 1152.	                        blinkPositionCheck = 0x000;
	XOR	A
	LD	(blinkPositionCheck),A
?0058:
; 1153.	                }
; 1154.	
; 1155.	                blinkCount++;
	LD	HL,blinkCount
	INC	(HL)
; 1156.	                if( blinkCount>=50 ){           /*éTéOéOéŹérāJāEāōāgé╠ā`āFābāN*/
	LD	A,(blinkCount)
	CP	50
	JR	C,?0060
?0059:
; 1157.	                        blinkCount=0;
	XOR	A
	LD	(blinkCount),A
?0060:
; 1158.	                }
; 1159.	}
	RET
