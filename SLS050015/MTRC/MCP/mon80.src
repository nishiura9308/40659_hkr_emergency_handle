; ƒ‚ƒjƒ^ƒvƒچƒOƒ‰ƒ€‚ھ“®چى‚إ‚«‚é‚½‚ك‚جچإ’لŒہ‚جڈ‰ٹْ‰»
; ‚ًچs‚ب‚ء‚ؤ‚­‚¾‚³‚¢پB
; —ل‚¦‚خپA
;  1.‚c‚q‚`‚l‚جƒٹƒtƒŒƒVƒ…ƒRƒ“ƒgƒچپ[ƒ‰‚جڈ‰ٹْ‰»(64180etc.)
;  2.‚v‚`‚h‚sƒRƒ“ƒgƒچپ[ƒ‰‚جڈ‰ٹْ‰»(64180etc.)
;  3.‚»‚ج‘¼•K—v‚بƒnپ[ƒhƒEƒFƒA‚جچإ’لŒہ‚جڈ‰ٹْ‰»
; ƒŒƒWƒXƒ^‚ج•غ‘¶‚ح•K—v‚ ‚è‚ـ‚¹‚ٌپB
;
; ڈ‰ٹْ‰»ƒ‹پ[ƒ`ƒ“‚ً‹Lڈq‚·‚é—جˆو‚حUSRINI1‚ئUSRINIT2‚ج‚Qƒ–ڈٹ‚ ‚è‚ـ‚· 
; USRINIT1(‚±‚ج•”•ھ)‚ة‹Lڈq‚إ‚«‚éƒoƒCƒgگ”‚ح37HƒoƒCƒg‚إ‚·پB‚à‚µپA‚±‚ج—جˆو‚ة
; ‚·‚×‚ؤ‚جƒRپ[ƒh‚ھ‹Lڈq‚إ‚«‚ب‚¢ڈêچ‡‚حUSRINIT2‚ة•ھ‚¯‚ؤڈ‘‚¢‚ؤ‚­‚¾‚³‚¢پB
;============================================================
USRINIT:
;----------------------------------------
; ‚±‚ج•”•ھ‚ةڈ‰ٹْ‰»ƒ‹پ[ƒ`ƒ“‚ًڈ‘‚«‰ء‚¦‚ـ‚·
;----------------------------------------
;-------- 64180 Sample (0WAIT , No Refresh) -------
	xor	a
	out0	(32h),a
	out0	(36h),a

	ld	a,0c8h		; BANK_LOW .. 0x4000 , COMMON_LOW .. 0xc000
	out0	(3ah),a

	ld	a,14h		; 0x3c000 - 0xc000 = 0x30000 ( COMMON BASE )
	out0	(38h),a
;-------------------------------------------------
;--------- TMPZ84C015BF --------------------------
;	LD	A,03h
;	OUT	(0F0h),A
;	LD	A,0B1h
;	OUT	(0F1h),A
;
;======== KC80 Sample (NMI,MMU) ===========
;	ld	a,0fh		; B1 = 0f ( 0x4000 )
;	out	(00h),a
;	ld	a,032h		; B4 = 32 ( 0xCC00 )
;	out	(06h),a
;	ld	a,08h
;	out	(3bh),a
;==========================================
;
;-------------------------------------
; ‚±‚جچs‚و‚è‰؛‚ح•دچX‹ضژ~
;-------------------------------------
	ld	a,(CMDRD)
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext

	.dephase
	org	01fc0h
	.phase	MONADR

	end
