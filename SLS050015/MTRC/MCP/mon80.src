;******************************************
	.dephase
	org	01800h
	.phase	MONADR

gcmd:
;================پƒ‚t‚r‚q‚f‚n‚q‚s‚mپ„===================
; ‚fƒRƒ}ƒ“ƒh“™‚إƒ†پ[ƒUƒvƒچƒOƒ‰ƒ€‚ھژہچs‚³‚ê‚é’¼‘O‚ة
; ‚±‚جƒ‹پ[ƒ`ƒ“‚ھŒؤ‚خ‚ê‚ـ‚·پBƒ†پ[ƒUƒvƒچƒOƒ‰ƒ€ژہچs‘O‚ة
; ƒCƒ“ƒ^ƒoƒ‹ƒ^ƒCƒ}“™‚جƒnپ[ƒh‚ًƒXƒ^پ[ƒg‚µ‚½‚¢ژ‍‚ة
; ‚±‚ج•”•ھ‚ة‹Lڈq‚µ‚ؤ‚­‚¾‚³‚¢پB’تڈي‚ح‰½‚à‹Lڈq‚µ‚ب‚­‚ؤ
; Œ‹چ\‚إ‚·پB
; ‚r‚oˆبٹO‚جƒŒƒWƒXƒ^‚ج•غ‘¶‚ح•K—v‚ ‚è‚ـ‚¹‚ٌپB
; ‚±‚ج•”•ھ‚إٹ„‚èچ‍‚ف‚ً‹ضژ~‚µ‚ؤ‚¨‚¯‚خپAƒ†پ[ƒUƒvƒچƒOƒ‰ƒ€
; ‚ةگ§Œن‚ھˆع‚é‚ـ‚إٹ„‚èچ‍‚ف‹ضژ~‚إ‘–‚è‚ـ‚·پB
;========================================================
usrgortn:
;
; ‚±‚ج•”•ھ‚ةڈˆ—‌ƒ‹پ[ƒ`ƒ“‚ً‹Lڈq‚µ‚ـ‚·پB
;

;-----------------------------------------------

;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext

	.dephase
	org	01840h
	.phase	MONADR
gcmd1:
	di
;	GETW
		ld	hl,l_34
		jp	getrs
		l_34:
		ld	e,a
		ld	hl,l_35
		jp	getrs
		l_35:
		ld	d,a
	ex	de,hl
	ld	sp,hl		; USER STACK
;	GETW
		ld	hl,l_36
		jp	getrs
		l_36:
		ld	e,a
		ld	hl,l_37
		jp	getrs
		l_37:
		ld	d,a
	push	de		; PC
;	GETW
		ld	hl,l_38
		jp	getrs
		l_38:
		ld	e,a
		ld	hl,l_39
		jp	getrs
		l_39:
		ld	d,a
	push	de		; AF
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


	.dephase
	org	01880h
	.phase	MONADR
;	GETW			; AF'
		ld	hl,l_40
		jp	getrs
		l_40:
		ld	e,a
		ld	hl,l_41
		jp	getrs
		l_41:
		ld	d,a
	push	de
	pop	af
	ex	af,af'
;	GETW			; BC'
		ld	hl,l_42
