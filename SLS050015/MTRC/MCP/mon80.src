;************************
;****** NON SHADOW ******
;************************
	.dephase
	org	019c0h
	.phase	MONADR

	xor	a
	or	b
	ld	a,(RUNON)		; @ i 1994.4.14
	jp	z,1$
	ei
1$:
	pop	hl
	pop	bc
;	ld	a,(RUNON)		; @@@ d 1994.4.14
	pop	af
	ret

nmientry:
	push	af
	ld	a,(STAT)		; HOST_NMI(Break)
	and	2			; Check HOST_NMI(Break)
	jp	nz,nmibrk
;-- User NMI --
	pop	af
usrnmip:
	jp	0			; jmp to USR NMI

nmibrk:
	ld	a,(CLRNMI)		; NMI Request CLR
	ld	a,(RUNOFF)

	ld	a,1
	jr	next_brk

;===== Break/Step End Entry =====
bpret:
	push	af
	ld	a,(RUNOFF)
;--eidichk--
	ld	a,i
	jp	pe,1$		; EI
	ld	a,i		; retry for Z80/64180R0 Bug
	jp	pe,1$		; EI
	ld	a,i		; retry for Z80/64180R0 Bug
1$:
	di
	push	af		; I_MASK & (CY=0 not NMI)
	xor	a
next_brk:
	push	bc
	push	hl
;	PUTB_MAIN
		ld	hl,mainlp
		jp	putrs


;********************
;****** SHADOW ******
;********************
	.dephase
	org	01a00h
	.phase	MONADR

shadowentry:
;--- NMI entry ---
	push	af
	ld	a,(STAT)		; HOST_NMI(Break)
	and	2			; Check HOST_NMI(Break)
	jp	z,shadow_sbrk

	ld	a,(RUNOFF)
	ld	a,(CLRNMI)		; NMI Request CLR
	ld	a,1
	jp	shadow_next

;===== Break/Step End Entry =====
shadow_sbrk:
	ld	a,(RUNOFF)
;--eidichk--
	ld	a,i
	jp	pe,1$		; EI
	ld	a,i		; retry for Z80/64180R0 Bug
	jp	pe,1$		; EI
	ld	a,i		; retry for Z80/64180R0 Bug
1$:
	di
	push	af		; I_MASK & (CY=0 not NMI)
	xor	a
shadow_next:
	push	bc
	push	hl
;	PUTB_MAIN
		ld	hl,mainlp
		jp	putrs

shadow_gcmd:
	xor	a
	or	b
	jp	z,1$
	ei
1$:
	pop	hl
	pop	bc
	ld	a,RUNON-4
	ld	r,a
	pop	af
	jp	RUNON


