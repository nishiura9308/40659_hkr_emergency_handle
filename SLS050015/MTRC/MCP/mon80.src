;   •دچX‰سڈٹ‚PپFˆب‰؛‚جƒVƒ“ƒ{ƒ‹‚ًگف’è‚µ‚ؤ‚­‚¾‚³‚¢پB
;+++++++++++++++++++++++++++++++++++++++++++++++++++++++

;-------------- ƒ‚ƒjƒ^‚جƒRپ[ƒhƒAƒhƒŒƒX‚جگف’è ---------------------------------
; MONADR ¥¥¥¥ ƒ‚ƒjƒ^‚جژg—p‚·‚éƒRپ[ƒh—جˆو‚جگو“ھƒAƒhƒŒƒX‚ًگف’è‚µ‚ؤ‚­‚¾‚³‚¢
;-----------------------------------------------------------------------------
MONADR	equ	03f00h


;-------------- ƒ^پ[ƒQƒbƒg‚b‚o‚t‚جژي—ق‚ًژw’è‚µ‚ـ‚· ---------------------------
; CPU85 ...... 8085¼ط°½ق‚جڈêچ‡ 1 ‚ةƒZƒbƒg
; CPUZ80 ..... Z80(TMPZ84)¼ط°½ق‚جڈêچ‡ 1 ‚ةƒZƒbƒg
; CPU180 ..... HD64180¼ط°½ق‚جڈêچ‡ 1 ‚ةƒZƒbƒg
; KC80 ....... KC80(KAWATETSU)‚جڈêچ‡ 1 ‚ةƒZƒbƒg
; CPU1600 .... CPU1600(ROHM)‚جڈêچ‡ 1 ‚ةƒZƒbƒg
;-----------------------------------------------------------------------------
CPUNO	equ	2


;-------------- ƒ‚ƒjƒ^“®چىژ‍ٹ„‚èچ‍‚ف‹–‰آپ^‹ضژ~‚جگف’è -------------------------
; MONSTID ¥¥¥¥ ƒ‚ƒjƒ^“®چى’†‚حٹ„‚èچ‍‚ف‹ضژ~ڈَ‘ش‚جڈêچ‡ 1 ‚ةƒZƒbƒg
; MONSTIE ¥¥¥¥ ƒ‚ƒjƒ^“®چى’†‚حٹ„‚èچ‍‚ف‹–‰آڈَ‘ش‚جڈêچ‡ 1 ‚ةƒZƒbƒg
; MONSTIC ¥¥¥¥ ƒ‚ƒjƒ^“®چى’†‚حƒ†پ[ƒUƒvƒچƒOƒ‰ƒ€‚جڈَ‘ش‚ًˆّ‚«Œp‚®‚جڈêچ‡ 1 ‚ةƒZƒbƒg
;-----------------------------------------------------------------------------

;=============================================================
;  ‚±‚ج•”•ھˆبچ~ <•دچX‰سڈٹ‚Qپ„ ‚ـ‚إ‚حپA•دچX‚µ‚ب‚¢‚إ‚­‚¾‚³‚¢پB
;=============================================================

{r0}	macro
b	=	0
c	=	8
d	=	10h
e	=	18h
h	=	20h
l	=	28h
a	=	38h
	endm

{r1}	macro
b	=	0
c	=	8
d	=	10h
e	=	18h
h	=	20h
l	=	28h
(hl)	=	30h
a	=	38h
	endm

{d0}	macro
bc	=	4ch
de	=	5ch
hl	=	6ch
sp	=	7ch
	endm

<out0 (*),*> macro x,y
	db	0edh,01h+{r0=y},x
	endm

<in0 *,(*)> macro x,y
	db	0edh,{r0=x},y
	endm

CMDRD	equ	MONADR+45h
CLRNMI	equ	MONADR+40h
STAT	equ	MONADR+41h
RUNOFF	equ	MONADR+47h
RUNON	equ	MONADR+46h
CMDWR0	equ	MONADR+43h
CMDWR1	equ	MONADR+42h
CMDWRE  equ	MONADR+44h

	org	0
	.phase	MONADR

shadowbrk1 equ	$
cmdstart equ	$
	db	01h		; Table Mark				/ 0h
	db	CPUNO		; CPUƒ^ƒCƒv(0,1,2=8085,Z80,64180)	/ 1h
	db	7
	dw	MONADR		; ƒ‚ƒjƒ^‚جƒRپ[ƒhƒXƒ^پ[ƒgƒAƒhƒŒƒX	/ 3h
	dw	0
	dw	usrnmip+67h*40h-MONADR
				; ƒ†پ[ƒU‚m‚l‚hپi‚s‚q‚`‚oپjpachiƒAƒhƒŒƒX / 7h
	dw	nmientry	; NMI Entry point			/ 9h
	dw	bpret		; SOFT BP Entry(NON SHADOW)		/ bh
	dw	shadowentry	; NMI Entry point(LOW)			/ dh
	dw	shadow_high	; NMI Entry point(HIGH)			/ fh
	dw	0
	.dephase

	org	CLRNMI-MONADR
	db	0ffh				;SOFTBRK*8+0c7h

	org	RUNON-MONADR
	ret

;******************************************
;	ƒRƒ‚ƒ“ƒoƒ“ƒN
;******************************************

	org	48h
	.phase	MONADR+48h

mainlp:
	ld	hl,cmdstart
	nop

;---- 1Byte RX ----
getrs:
	ld	a,(STAT)
	and	8
	jp	z,getrs
getrs1:
	ld	a,(CMDRD)
	jp	(hl)

;---- 1Byte TX ----
putrs:
	ld	c,8
	ld	b,a
prsl:
	ld	a,(STAT)
	and	4
	jp	z,prsl
prsl0:
	ld	a,b
	rla
	ld	b,a
	jp	c,prs1
	ld	a,(CMDWR0)
	jp	prs2
prs1:
	ld	a,(CMDWR1)
prs2:
	dec	c
	jp	nz,prsl0
bnext:
	ld	a,(CMDWRE)
	jp	(hl)

	org	MONADR+7dh
shadow_high:
	jp	shadowentry

;******************************************
;	PEEKB
;******************************************
	.dephase
	org	0200h
	.phase	MONADR
peekb:
;	GETW		; DE <- addres
		ld	hl,l_0
		jp	getrs
		l_0:
		ld	e,a
		ld	hl,l_1
		jp	getrs
		l_1:
		ld	d,a
	ld	a,(de)
;	PUTB_MAIN
		ld	hl,mainlp
		jp	putrs

;******************************************
;	INPB
;******************************************
	.dephase
	org	0240h
	.phase	MONADR

;---- inportB -----
inpb:
;	GETW		; DE <- addres
		ld	hl,l_2
		jp	getrs
		l_2:
		ld	e,a
		ld	hl,l_3
		jp	getrs
		l_3:
		ld	d,a

	ld	b,d
	ld	c,e
	in	a,(c)
;	PUTB_MAIN
		ld	hl,mainlp
		jp	putrs


;******************************************
;	PEEKW
;******************************************
	.dephase
	org	0400h
	.phase	MONADR
peekw:
;	GETW		; DE <- addres
		ld	hl,l_4
		jp	getrs
		l_4:
		ld	e,a
		ld	hl,l_5
		jp	getrs
		l_5:
		ld	d,a
	ld	a,(de)
;	PUTB
		ld	hl,l_6
		jp	putrs
		l_6:
	inc	de
	ld	a,(de)
;	PUTB_MAIN
		ld	hl,mainlp
		jp	putrs

;******************************************
;	POKEB
;******************************************
	.dephase
	org	0600h
	.phase	MONADR
pokeb:
;	GETW		; DE <- addres
		ld	hl,l_7
		jp	getrs
		l_7:
		ld	e,a
		ld	hl,l_8
		jp	getrs
		l_8:
		ld	d,a
;	GETB
		ld	hl,l_9
		jp	getrs
		l_9:
	ld	(de),a
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


;******************************************
;	OUTB
;******************************************
	.dephase
	org	0640h
	.phase	MONADR
outpb:
;	GETW			; DE <- addres
		ld	hl,l_10
		jp	getrs
		l_10:
		ld	e,a
		ld	hl,l_11
		jp	getrs
		l_11:
		ld	d,a
;	GETB			; a <- data
		ld	hl,l_12
		jp	getrs
		l_12:
	ld	b,d
	ld	c,e
	out	(c),a
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


;******************************************
;	POKEW
;******************************************
	.dephase
	org	0800h
	.phase	MONADR
pokew:
;	GETW		; DE <- addres
		ld	hl,l_13
		jp	getrs
		l_13:
		ld	e,a
		ld	hl,l_14
		jp	getrs
		l_14:
		ld	d,a
;	GETB
		ld	hl,l_15
		jp	getrs
		l_15:
	ld	(de),a
	inc	de
;	GETB
		ld	hl,l_16
		jp	getrs
		l_16:
	ld	(de),a
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


;******************************************
;	GETBLK
;******************************************
	.dephase
	org	0a00h
	.phase	MONADR
getblk:
;	GETW		; DE <- addres
		ld	hl,l_17
		jp	getrs
		l_17:
		ld	e,a
		ld	hl,l_18
		jp	getrs
		l_18:
		ld	d,a
gblklp:
	ld	a,(de)
	inc	de
;	PUTB
		ld	hl,l_19
		jp	putrs
		l_19:
;	GETB
		ld	hl,l_20
		jp	getrs
		l_20:
	or	a
	jp	nz,gblklp
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


;******************************************
;	PUTBLK
;******************************************
	.dephase
	org	0c00h
	.phase	MONADR

putblk:
;	GETW		; DE <- address
		ld	hl,l_21
		jp	getrs
		l_21:
		ld	e,a
		ld	hl,l_22
		jp	getrs
		l_22:
		ld	d,a
pblklp:
;	GETB
		ld	hl,l_23
		jp	getrs
		l_23:
	ld	(de),a
	inc	de
;	GETB
		ld	hl,l_24
		jp	getrs
		l_24:
	or	a
	jp	nz,pblklp
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


;******************************************
;	SPSET
;******************************************
	.dephase
	org	01400h
	.phase	MONADR

;	GETW
		ld	hl,l_25
		jp	getrs
		l_25:
		ld	e,a
		ld	hl,l_26
		jp	getrs
		l_26:
		ld	d,a
	ex	de,hl
	ld	sp,hl		; USER STACK
	ld	a,(CLRNMI)	; NMI Request CLR
	ld	a,(RUNOFF)
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext


;******************************************
;	FLGSET
;******************************************
	.dephase
	org	01440h
	.phase	MONADR
flgset:
;	GETB
		ld	hl,l_27
		jp	getrs
		l_27:
	or	a
	jp	z,flgs1
	ei
	jp	flgs2
flgs1:
	di
flgs2:
;	BANK_NEXT
		ld	hl,mainlp
		jp	bnext

;******************************************
;	MMUGET_KC80
;******************************************
	.dephase
	org	01480h
	.phase	MONADR
mmuget_kc80:

	ld	bc,0
mmg_kc0:
	in	a,(c)
	exx
;	PUTB
		ld	hl,l_28
		jp	putrs
		l_28:
	exx
	inc	c
	ld	a,c
	cp	7
	jr	nz,mmg_kc0
	in	a,(c)
;	PUTB_MAIN
		ld	hl,mainlp
		jp	putrs

;******************************************
;	MMUSET_KC80
