; 286.	        Revision                a00 2000/06/27
; 287.	
; 288.	*************************************************************************/
; 289.	void paaExecuteMAN( void )
; 290.	{
	PUSH	BC
	PUSH	DE
; 291.	                if( befOpeMode!=opeMode ){
	LD	A,(opeMode)
	LD	B,A
	LD	A,(befOpeMode)
	CP	B
	JR	Z,?0038
?0037:
; 292.	                        befOpeMode = opeMode;
	LD	A,(opeMode)
	LD	(befOpeMode),A
; 293.	                        io_output_on2( 0xC0 );                  /* AMP1, AMP2 on */
	LD	E,192
	CALL	io_output_on2
; 294.	                        io_output_on4( 0xC0 );
	LD	E,192
	CALL	io_output_on4
; 295.	                        io_output_on1( 0x1F );                  /* RSC Gate OFF */
	LD	E,31
	CALL	io_output_on1
; 296.	                        io_output_on2( 0x3F );                  /* All Speaker ON */
	LD	E,63
	CALL	io_output_on2
; 297.	                        io_output_on1( 0x20 );                  /* RSC Switch gate ON */
	LD	E,32
	CALL	io_output_on1
; 298.	                        amp1Active = 1;
	LD	A,1
	LD	(amp1Active),A
; 299.	                        amp2Active = 1;
	LD	A,1
	LD	(amp2Active),A
; 300.	                        ampFailCount1 = 0;
	LD	HL,0
	LD	(ampFailCount1),HL
; 301.	                        ampFailCount2 = 0;
	LD	HL,0
	LD	(ampFailCount2),HL
?0038:
; 302.	                }
; 303.	
; 304.	                paaAMPCheck();
	CALL	paaAMPCheck
; 305.	}
	POP	DE
	POP	BC
	RET
paaExecuteCAB:
; 306.	
; 307.	
; 308.	/************************************************************************
; 309.	
; 310.	        Function name   << paaExecuteCAB >>
; 311.	                                        ＣＡＢ／ＣＡＢモードの処理
; 312.	        Syntax                  paaExecuteCAB( void );
; 313.	        Argument                none
; 314.	        Author                  TOA Corporation  K.Honda
; 315.	        Revision                a00 2000/06/27
; 316.	                                        a01 2001/05/23 スピーカー６のＯＦＦを行なっていなかったのを修正
; 317.	*************************************************************************/
; 318.	void paaExecuteCAB( void )
; 319.	{
	PUSH	BC
	PUSH	DE
; 320.	                if( befOpeMode!=opeMode ){
	LD	A,(opeMode)
	LD	B,A
	LD	A,(befOpeMode)
	CP	B
	JR	Z,?0040
?0039:
; 321.	                        befOpeMode = opeMode;
	LD	A,(opeMode)
	LD	(befOpeMode),A
; 322.	                        io_output_off2( 0xC0 );                 /* AMP1, AMP2 off */
	LD	E,192
	CALL	io_output_off2
; 323.	                        io_output_off4( 0xC0 );
	LD	E,192
	CALL	io_output_off4
; 324.	                        io_output_on1( 0x1F );                  /* RSC Gate OFF */
	LD	E,31
	CALL	io_output_on1
; 325.	                        io_output_off2( 0x3F );                 /* All Speaker OFF */
	LD	E,63
	CALL	io_output_off2
