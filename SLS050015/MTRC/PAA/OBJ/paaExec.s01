; 396.	                                a01 2000/11/07 ５秒間のチェック間隔
; 397.	                                a02 2001/04/16 スピーカーを切り替えてから２秒間ウェイト
; 398.	                                a03 2001/05/23 スピーカー６のＯＦＦを行なっていなかったのを修正
; 399.	*************************************************************************/
; 400.	void paaExecuteTEST( void )
; 401.	{
	PUSH	BC
	PUSH	DE
; 402.	                if( befOpeMode!=opeMode ){
	LD	A,(opeMode)
	LD	B,A
	LD	A,(befOpeMode)
	CP	B
	JR	Z,?0052
?0051:
; 403.	                        befOpeMode = opeMode;
	LD	A,(opeMode)
	LD	(befOpeMode),A
; 404.	                        io_output_on2( 0xC0 );                  /* AMP1, AMP2 on */
	LD	E,192
	CALL	io_output_on2
; 405.	                        io_output_on4( 0xC0 );
	LD	E,192
	CALL	io_output_on4
; 406.	                        io_output_on1( 0x1F );                  /* RSC Gate OFF */
	LD	E,31
	CALL	io_output_on1
; 407.	                        io_output_off2( 0x3F );                 /* All Speaker OFF */
	LD	E,63
	CALL	io_output_off2
; 408.	                        io_output_off1( 0x20 );                 /* RSC Switch gate OFF */
	LD	E,32
	CALL	io_output_off1
; 409.	
; 410.	                        sendarea.trouble = 0;
	XOR	A
	LD	(sendarea+4),A
; 411.	
; 412.	                        testCount = 0;
	LD	HL,0
	LD	(testCount),HL
; 413.	                        testRSCNo = 0;
	XOR	A
	LD	(testRSCNo),A
; 414.	                        befTestRSCNo = 1;
	LD	A,1
	LD	(befTestRSCNo),A
; 415.	
; 416.	                        amp1Active = 1;
	LD	A,1
	LD	(amp1Active),A
; 417.	                        amp2Active = 1;
	LD	A,1
	LD	(amp2Active),A
; 418.	                        ampok = 0;
	XOR	A
	LD	(ampok),A
; 419.	                        testPhase = 0;
	XOR	A
	LD	(testPhase),A
?0052:
; 420.	                }
; 421.	
; 422.	                if( testRSCNo >= 5 ){
	LD	A,(testRSCNo)
	CP	5
	JR	C,?0054
?0053:
; 423.	                        testRSCNo = 0;
	XOR	A
	LD	(testRSCNo),A
?0054:
; 424.	                }
; 425.	
; 426.	                if( (nowReadIO & IN_24V)==0 ){
	LD	HL,(nowReadIO)
	LD	A,L
	AND	0
	LD	B,A
	LD	A,H
	AND	16
	OR	B
	JR	NZ,?0056
?0055:
; 427.	                        return;
; 428.	                }
	JP	?0093
?0056:
; 429.	
; 430.	                if( nowReadIO & AMPON1 ){
	LD	HL,(nowReadIO)
	LD	A,L
	AND	0
	LD	B,A
	LD	A,H
	AND	4
	OR	B
	JR	Z,?0058
?0057:
; 431.	                        ampok |= AMPON1;
	LD	A,(ampok)
	OR	0
	LD	(ampok),A
; 432.	                        sendarea.trouble &= ~0x01;
	LD	A,(sendarea+4)
	AND	254
	LD	(sendarea+4),A
?0058:
; 433.	                }
; 434.	                if( nowReadIO & AMPON2 ){
	LD	HL,(nowReadIO)
	LD	A,L
	AND	0
	LD	B,A
	LD	A,H
	AND	8
	OR	B
	JR	Z,?0060
?0059:
; 435.	                        ampok |= AMPON2;
	LD	A,(ampok)
	OR	0
	LD	(ampok),A
; 436.	                        sendarea.trouble &= ~0x02;
	LD	A,(sendarea+4)
	AND	253
	LD	(sendarea+4),A
?0060:
; 437.	                }
; 438.	
; 439.	                /* 放送中 */
; 440.	                if( (ampok & AMPON1)==0 ){
	LD	A,(ampok)
	AND	0
	JR	NZ,?0062
?0061:
; 441.	                        if( ampFailCount1>=100 ){
	LD	BC,32868
	LD	HL,(ampFailCount1)
	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	C,?0064
?0063:
; 442.	                                ampFailCount1 = 100;
