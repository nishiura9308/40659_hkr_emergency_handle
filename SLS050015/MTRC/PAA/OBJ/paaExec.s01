?0064:
; 446.	                                sendarea.trouble &= ~0x01;
	LD	A,(sendarea+4)
	AND	254
	LD	(sendarea+4),A
?0065:
?0062:
; 447.	                        }
; 448.	                }
; 449.	                if( (ampok & AMPON2)==0 ){
	LD	A,(ampok)
	AND	0
	JR	NZ,?0067
?0066:
; 450.	                        if( ampFailCount2>=100 ){
	LD	BC,32868
	LD	HL,(ampFailCount2)
	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	C,?0069
?0068:
; 451.	                                ampFailCount2 = 100;
	LD	HL,100
	LD	(ampFailCount2),HL
; 452.	                                sendarea.trouble | 0x02;
; 453.	                        }
; 454.	                        else {
	JR	?0070
?0069:
; 455.	                                sendarea.trouble &= ~0x02;
	LD	A,(sendarea+4)
	AND	253
	LD	(sendarea+4),A
?0070:
?0067:
; 456.	                        }
; 457.	                }
; 458.	
; 459.	                if( befTestRSCNo != testRSCNo ){
	LD	A,(testRSCNo)
	LD	B,A
	LD	A,(befTestRSCNo)
	CP	B
	JR	Z,?0072
?0071:
; 460.	                        befTestRSCNo = testRSCNo;
	LD	A,(testRSCNo)
	LD	(befTestRSCNo),A
; 461.	
; 462.	                        testPhase = 0;
	XOR	A
	LD	(testPhase),A
?0072:
; 463.	                }
; 464.	
; 465.	                if( testPhase==0 ){             /* スピーカーとマイクをすべてＯＦＦにし、音声が入っていないことを確認する*/
	LD	A,(testPhase)
