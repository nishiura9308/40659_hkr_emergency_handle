?0086:
; 499.	                        testTrouble = 0;
	XOR	A
	LD	(testTrouble),A
?0087:
; 500.	                }
; 501.	
; 502.	                if( testCount>=500 ){   /* ５秒間の確認時間 */
	LD	BC,33268
