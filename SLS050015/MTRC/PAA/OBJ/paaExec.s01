	NAME	paaexec(16)
	RSEG	CODE(0)
	RSEG	UDATA0(0)
	EXTERN	address
	PUBLIC	amp1Active
	PUBLIC	amp2Active
	PUBLIC	ampFailCount1
	PUBLIC	ampFailCount2
	EXTERN	csio_output
	PUBLIC	emg_rsc
	PUBLIC	initial_voice_level
	EXTERN	io_output_off1
	EXTERN	io_output_off2
	EXTERN	io_output_off3
	EXTERN	io_output_off4
	EXTERN	io_output_on1
	EXTERN	io_output_on2
	EXTERN	io_output_on3
	EXTERN	io_output_on4
	PUBLIC	ledCount
	PUBLIC	noise_checkCount
	EXTERN	nowReadIO
	PUBLIC	opeMode
	PUBLIC	paaAMPCheck
	PUBLIC	paaExecuteAUTO
	PUBLIC	paaExecuteCAB
	PUBLIC	paaExecuteEMG
	PUBLIC	paaExecuteINIT
	PUBLIC	paaExecuteMAN
	PUBLIC	paaExecuteMode
	PUBLIC	paaExecuteTEST
	PUBLIC	paaGetMode
	PUBLIC	paaLEDOUT
	PUBLIC	paaSetVolume
	EXTERN	sendarea
	PUBLIC	testCount
	PUBLIC	voice_bus_mode
	EXTERN	?CL64180L_4_04_L00
	EXTERN	?C_LSH_L01
	EXTERN	?SS_RSH_L02
	EXTERN	?C_S_SWITCH_L06
	EXTERN	?C_V_SWITCH_L06
	RSEG	CODE
paaGetMode:
; 1.	/********************************************************************
; 2.	        【香港地下鉄向け自動列車放送制御装置】
; 3.	*-------------------------------------------------------------------*
; 4.	        実行制御モジュール
; 5.	*-------------------------------------------------------------------*
; 6.	        Author          TOA Corporation
; 7.	
; 8.	        Revision        a00. 2000/06/27         K.Honda
; 9.	
; 10.	*********************************************************************/
; 11.	
; 12.	#include "IOFUNC.h"
; 13.	
; 14.	#include "COMMDEF.h"
; 15.	
; 16.	/*@@@S*/
; 17.	/*・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; 18.	        グローバル変数
; 19.	・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・*/
; 20.	/** 音声バスモード **/
; 21.	char    voice_bus_mode;
; 22.	
; 23.	char    emg_rsc;                                /*非常通報器番号フラグ*/
; 24.	
; 25.	char    initial_voice_level;    /*基本音量データ
; 26.	                                                                        下位６ビットのみ使用
; 27.	                                                                */
; 28.	
; 29.	short   noise_checkCount;               /* 騒音検出カウンター */
; 30.	char    amp1Active;
; 31.	char    amp2Active;
; 32.	short   ampFailCount1;          /* アンプフェイルカウンターＣＨ。１ */
; 33.	short   ampFailCount2;          /* アンプフェイルカウンターＣＨ。２ */
; 34.	short   testCount;                      /* テスト用カウンター */
; 35.	char    ledCount;                       /* ＬＥＤ点滅カウンター */
; 36.	
; 37.	/*・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; 38.	        ローカル定数定義
; 39.	・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・*/
; 40.	/** 操作モード **/
; 41.	#define OPE_INIT        0
; 42.	#define OPE_CAB         1
; 43.	#define OPE_MAN         2
; 44.	#define OPE_EMG         3
; 45.	#define OPE_TRS         4
; 46.	#define OPE_AUTO        5
; 47.	#define OPE_TEST        6
; 48.	
; 49.	
; 50.	/*・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; 51.	        ローカル構造体定義
; 52.	・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・*/
; 53.	
; 54.	/*・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; 55.	        ローカルテーブル
; 56.	・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・*/
; 57.	
; 58.	/*・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; 59.	                外部参照
; 60.	・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・*/
; 61.	
; 62.	/** スイッチデータ **/
; 63.	extern  short   nowReadIO;
; 64.	#define IN_24V  0x1000
; 65.	#define AMPON1  0x0400
; 66.	#define AMPON2  0x0800
; 67.	#define MICON   0x0020
; 68.	
; 69.	/** 送信エリア **/
; 70.	extern  struct PAASEND  sendarea;
; 71.	
; 72.	
; 73.	extern  unsigned short  address;                        /* 上位１２ビット＝Ｃａｒ　Ｎｏ．
; 74.	                                                                                   下位４ビット＝ＤＩＰＳＷアドレス */
; 75.	
; 76.	/*・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; 77.	                ローカル変数
; 78.	・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・*/
; 79.	static  short   checkAmp;                       /* 騒音検出するアンプ */
; 80.	static  char    befNoiseLevel;          /* 前回ノイズレベル */
; 81.	static  char    befOpeMode;                     /* 前回の音声バスモード */
; 82.	static  char    testRSCNo;                      /* テスト用非常通報器番号 */
; 83.	static  char    befTestRSCNo;           /* 前回テスト用非常通報器番号 */
; 84.	static  char    testTrouble;            /* テスト用非常通報器ビット */
; 85.	static  char    ampok;
; 86.	static  char    bef_emg_rsc;            /* 前回の非常通報器ビット */
; 87.	static  char    testPhase;                      /* 音声マイク検出フェーズ */
; 88.	
; 89.	/** 操作モード **/
; 90.	char    opeMode;                                /*操作モード*/
; 91.	
; 92.	/*@@@E*/
; 93.	/************************************************************************
; 94.	
; 95.	        Function name   << paaGetMode >>
; 96.	                                        操作モードの取得
; 97.	        Syntax                  paaGetMode( void );
; 98.	        Argument                none
; 99.	        Author                  TOA Corporation  K.Honda
; 100.	        Revision                a00 2000/06/27
; 101.	
; 102.	*************************************************************************/
; 103.	void paaGetMode( void )
; 104.	{
	PUSH	DE
; 105.	#if 0
; 106.	                io_output_off4( 0x07 );
; 107.	                io_output_on4( voice_bus_mode & 0x07 );
; 108.	#else
; 109.	                io_output_off4( 0x0F );
	LD	E,15
	CALL	io_output_off4
; 110.	                io_output_on4( (address >> 8) & 0x0F );
	LD	HL,(address)
	LD	L,H
	LD	H,0
	LD	A,L
	AND	15
	LD	E,A
	CALL	io_output_on4
; 111.	#endif
; 112.	
; 113.	                switch( voice_bus_mode & 0x00F ){
	LD	A,(voice_bus_mode)
	AND	15
	LD	E,A
	CALL	?C_V_SWITCH_L06
	DEFW	7
	DEFB	0
	DEFB	1
	DEFB	2
	DEFB	3
	DEFB	4
	DEFB	5
	DEFB	15
	DEFW	?0000
	DEFW	?0007
	DEFW	?0006
	DEFW	?0005
	DEFW	?0004
	DEFW	?0003
	DEFW	?0002
	DEFW	?0001
?0001:
; 114.	                case    0x00:           /* CAB/CAB */
; 115.	                        opeMode = OPE_CAB;
	LD	A,1
	LD	(opeMode),A
; 116.	                        break;
	JR	?0000
?0002:
; 117.	                case    0x01:           /* Manual */
; 118.	                        opeMode = OPE_MAN;
	LD	A,2
	LD	(opeMode),A
; 119.	                        break;
	JR	?0000
?0003:
; 120.	                case    0x02:           /* Emergency */
; 121.	                        opeMode = OPE_EMG;
	LD	A,3
	LD	(opeMode),A
; 122.	                        break;
	JR	?0000
?0004:
; 123.	                case    0x03:           /* TRS */
; 124.	                        opeMode = OPE_TRS;
	LD	A,4
	LD	(opeMode),A
; 125.	                        break;
	JR	?0000
?0005:
; 126.	                case    0x04:           /* AUTO */
; 127.	                        opeMode = OPE_AUTO;
	LD	A,5
	LD	(opeMode),A
; 128.	                        break;
	JR	?0000
?0006:
; 129.	                case    0x05:           /* TEST */
; 130.	                        opeMode = OPE_TEST;
	LD	A,6
	LD	(opeMode),A
; 131.	                        break;
	JR	?0000
?0007:
; 132.	                case    0x0F:           /* Initial */
; 133.	                        opeMode = OPE_INIT;
	XOR	A
	LD	(opeMode),A
; 134.	                        break;
	JR	?0000
?0000:
; 135.	                }
; 136.	
; 137.	}
	POP	DE
	RET
paaSetVolume:
; 138.	
; 139.	/************************************************************************
; 140.	
; 141.	        Function name   << paaSetVolume >>
; 142.	                                        操作モードの取得
; 143.	        Syntax                  paaSetVolume( void );
; 144.	        Argument                none
; 145.	        Author                  TOA Corporation  K.Honda
; 146.	        Revision                a00 2000/06/27
; 147.	                                        a01 2000/10/10  CH.1 のチェックのみ
; 148.	                                        a02 2003/07/07  h.nisiura AGCステップを6→4に変更
; 149.	*************************************************************************/
; 150.	void paaSetVolume( void )
; 151.	{
	PUSH	BC
	PUSH	DE
	PUSH	IX
	LD	IX,0
	ADD	IX,SP
	PUSH	AF
	PUSH	AF
	PUSH	AF
; 152.	                char    noiseLevel,nowNoise;
; 153.	                char    level;
; 154.	                unsigned short  setValue;
; 155.	
; 156.	                if( opeMode!=OPE_AUTO ){
	LD	A,(opeMode)
	CP	5
	JR	Z,?0009
?0008:
; 157.	                        noise_checkCount=0;
	LD	HL,0
	LD	(noise_checkCount),HL
; 158.	                        return;
; 159.	                }
	JP	?0026
?0009:
; 160.	
; 161.	                        /* 音声バス２４Ｖを認識中は、音量調整しない */
; 162.	                if( nowReadIO & IN_24V ){
	LD	HL,(nowReadIO)
	LD	A,L
	AND	0
	LD	B,A
	LD	A,H
	AND	16
	OR	B
	JR	Z,?0011
?0010:
; 163.	                        noise_checkCount=0;
	LD	HL,0
	LD	(noise_checkCount),HL
; 164.	                        return;
; 165.	                }
	JP	?0026
?0011:
; 166.	
; 167.	                if( noise_checkCount<30 ){
	LD	BC,32798
	LD	HL,(noise_checkCount)
	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	NC,?0013
?0012:
; 168.	                        return;
; 169.	                }
	JP	?0026
?0013:
; 170.	                noise_checkCount=0;
	LD	HL,0
	LD	(noise_checkCount),HL
; 171.	
; 172.	                noiseLevel = (nowReadIO & 0x0300)>>8;
	LD	HL,(nowReadIO)
	LD	A,L
	AND	0
	LD	E,A
	LD	A,H
	AND	3
	LD	D,A
	LD	B,8
	CALL	?SS_RSH_L02
	LD	(IX-6),E
; 173.	
; 174.	                nowNoise = noiseLevel;
	LD	(IX-5),E
; 175.	                if( befNoiseLevel < noiseLevel ){
	LD	A,(befNoiseLevel)
	CP	(IX-6)
	JR	NC,?0015
?0014:
; 176.	                        nowNoise = befNoiseLevel;
	LD	A,(befNoiseLevel)
	LD	(IX-5),A
?0015:
; 177.	                }
; 178.	
; 179.	                if( nowNoise==0 ){              /* 最小 */
	XOR	A
	OR	(IX-5)
	JR	NZ,?0017
?0016:
; 180.	                        level = initial_voice_level + 8;                /* -8dB */
	LD	A,(initial_voice_level)
	ADD	A,8
	LD	(IX-4),A
?0017:
; 181.	                }
; 182.	                if( nowNoise==1 ){              /* 中 */
	LD	B,(IX-5)
	DEC	B
	JR	NZ,?0019
?0018:
; 183.	                        level = initial_voice_level + 4;                /* -4dB */
	LD	A,(initial_voice_level)
	ADD	A,4
	LD	(IX-4),A
?0019:
; 184.	                }
; 185.	                if( nowNoise==2 ){              /* 最大 */
	LD	B,(IX-5)
	DEC	B
	DEC	B
	JR	NZ,?0021
?0020:
; 186.	                        level = initial_voice_level + 0;                /* -0dB */
	LD	A,(initial_voice_level)
	LD	(IX-4),A
?0021:
; 187.	                }
; 188.	                if( nowNoise==3 ){              /* 最大 */
	LD	A,(IX-5)
	CP	3
	JR	NZ,?0023
?0022:
; 189.	                        level = initial_voice_level + 0;                /* -0dB */
	LD	A,(initial_voice_level)
	LD	(IX-4),A
?0023:
; 190.	                }
; 191.	                if( level>0x3E ){
	LD	A,62
	CP	(IX-4)
	JR	NC,?0025
?0024:
; 192.	                        level = 0x3E;
	LD	(IX-4),62
?0025:
; 193.	                }
; 194.	                befNoiseLevel = noiseLevel;
	LD	B,(IX-6)
	LD	A,B
	LD	(befNoiseLevel),A
; 195.	
; 196.	#if 0
; 197.	                io_output_off4( 0x07 );
; 198.	                io_output_on4( befNoiseLevel & 0x07 );
; 199.	#endif
; 200.	
; 201.	                setValue = ((unsigned short)level<<2)+0x1803;   /* Left,Right Set, CS=L */
	LD	L,(IX-4)
	LD	H,0
	ADD	HL,HL
	ADD	HL,HL
	LD	BC,6147
	ADD	HL,BC
	LD	(IX-3),L
	LD	(IX-2),H
; 202.	                csio_output( setValue );                /* 出力 ( 13 bit )*/
	LD	E,L
	CALL	csio_output
; 203.	
; 204.	#if 0
; 205.	                checkAmp ^= 1;
; 206.	                if( checkAmp ){
; 207.	#endif
; 208.	                        io_output_off3( 0x01 );         /* AMP1 Noise Level ON */
	LD	E,1
	CALL	io_output_off3
; 209.	                        io_output_on3( 0x02 );          /* AMP2 Noise Level OFF */
	LD	E,2
	CALL	io_output_on3
; 210.	#if 0
; 211.	                }
; 212.	                else {
; 213.	                        io_output_on3( 0x01 );          /* AMP1 Noise Level OFF */
; 214.	                        io_output_off3( 0x02 );         /* AMP2 Noise Level ON */
; 215.	                }
; 216.	#endif
; 217.	}
?0026:
	LD	SP,IX
	POP	IX
	POP	DE
	POP	BC
	RET
paaAMPCheck:
; 218.	
; 219.	/************************************************************************
; 220.	
; 221.	        Function name   << paaAMPCheck >>
; 222.	                                        アンプ故障のチェック
; 223.	        Syntax                  paaAMPCheck( void );
; 224.	        Argument                none
; 225.	        Author                  TOA Corporation  K.Honda
; 226.	        Revision                a00 2000/06/27
; 227.	
; 228.	*************************************************************************/
; 229.	void paaAMPCheck( void )
; 230.	{
	PUSH	BC
; 231.	                        /* 放送中 */
; 232.	                if( nowReadIO & IN_24V ){
	LD	HL,(nowReadIO)
	LD	A,L
	AND	0
	LD	B,A
	LD	A,H
	AND	16
	OR	B
	JR	Z,?0028
?0027:
; 233.	                        if( ampFailCount1>=6000 ){
	LD	BC,38768
	LD	HL,(ampFailCount1)
	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	C,?0030
?0029:
; 234.	                                ampFailCount1 = 6000;
	LD	HL,6000
	LD	(ampFailCount1),HL
; 235.	                                sendarea.trouble | 0x01;
; 236.	                        }
; 237.	                        else {
	JR	?0031
?0030:
; 238.	                                sendarea.trouble &= ~0x01;
	LD	A,(sendarea+4)
	AND	254
	LD	(sendarea+4),A
?0031:
; 239.	                        }
; 240.	                        if( ampFailCount2>=6000 ){
	LD	BC,38768
	LD	HL,(ampFailCount2)
	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	C,?0033
?0032:
; 241.	                                ampFailCount2 = 6000;
	LD	HL,6000
	LD	(ampFailCount2),HL
; 242.	                                sendarea.trouble | 0x02;
; 243.	                        }
; 244.	                        else {
	JR	?0034
?0033:
; 245.	                                sendarea.trouble &= ~0x02;
	LD	A,(sendarea+4)
	AND	253
	LD	(sendarea+4),A
?0034:
?0028:
; 246.	                        }
; 247.	                }
; 248.	}
	POP	BC
	RET
paaExecuteAUTO:
; 249.	
; 250.	
; 251.	/************************************************************************
; 252.	
; 253.	        Function name   << paaExecuteAUTO >>
; 254.	                                        車内放送モードの処理
; 255.	        Syntax                  paaExecuteAUTO( void );
; 256.	        Argument                none
; 257.	        Author                  TOA Corporation  K.Honda
; 258.	        Revision                a00 2000/06/27
; 259.	
; 260.	*************************************************************************/
; 261.	void paaExecuteAUTO( void )
; 262.	{
	PUSH	BC
	PUSH	DE
; 263.	                if( befOpeMode!=opeMode ){
	LD	A,(opeMode)
	LD	B,A
	LD	A,(befOpeMode)
	CP	B
	JR	Z,?0036
?0035:
; 264.	                        befOpeMode = opeMode;
	LD	A,(opeMode)
	LD	(befOpeMode),A
; 265.	                        io_output_on2( 0xC0 );                  /* AMP1, AMP2 on */
	LD	E,192
	CALL	io_output_on2
; 266.	                        io_output_on4( 0xC0 );
	LD	E,192
	CALL	io_output_on4
; 267.	                        io_output_on1( 0x1F );                  /* RSC Gate OFF */
	LD	E,31
	CALL	io_output_on1
; 268.	                        io_output_on2( 0x3F );                  /* All Speaker ON */
	LD	E,63
	CALL	io_output_on2
; 269.	                        io_output_on1( 0x20 );                  /* RSC Switch gate ON */
	LD	E,32
	CALL	io_output_on1
; 270.	                        amp1Active = 1;
	LD	A,1
	LD	(amp1Active),A
; 271.	                        amp2Active = 1;
	LD	A,1
	LD	(amp2Active),A
; 272.	                        ampFailCount1 = 0;
	LD	HL,0
	LD	(ampFailCount1),HL
; 273.	                        ampFailCount2 = 0;
	LD	HL,0
	LD	(ampFailCount2),HL
?0036:
; 274.	                }
; 275.	
; 276.	                paaAMPCheck();
	CALL	paaAMPCheck
; 277.	}
	POP	DE
	POP	BC
	RET
paaExecuteMAN:
; 278.	
; 279.	/************************************************************************
; 280.	
; 281.	        Function name   << paaExecuteMAN >>
; 282.	                                        マニュアル放送モードの処理
; 283.	        Syntax                  paaExecuteMAN( void );
; 284.	        Argument                none
