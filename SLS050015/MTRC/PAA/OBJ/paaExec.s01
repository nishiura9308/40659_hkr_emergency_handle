; 351.	
; 352.	                        bef_emg_rsc = 0;
	XOR	A
	LD	(bef_emg_rsc),A
?0042:
; 353.	                }
; 354.	                if( emg_rsc & 0x07 ){   /* EMGP1-3 */
	LD	A,(emg_rsc)
	AND	7
	JR	Z,?0044
?0043:
; 355.	                        io_output_on2( 0x40 );                  /* AMP1 on */
