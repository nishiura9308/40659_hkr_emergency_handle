?0076:
; 471.	                        }
; 472.	                        return;
; 473.	                }
	JP	?0093
?0074:
; 474.	
; 475.	                if( testPhase==1 ){             /* スピーカーとマイクをＯＮにする */
	LD	A,(testPhase)
	DEC	A
	JR	NZ,?0078
?0077:
; 476.	                        testTrouble = 0x01<<testRSCNo;
	LD	A,(testRSCNo)
	LD	B,A
	LD	A,1
	CALL	?C_LSH_L01
	LD	(testTrouble),A
; 477.	                        io_output_on2( testTrouble );   /* Speaker ON by TEST RSC No. */
	LD	E,A
	CALL	io_output_on2
; 478.	                        if( testRSCNo==5 ){
	LD	A,(testRSCNo)
	CP	5
	JR	NZ,?0080
?0079:
; 479.	                                io_output_off1( 0x10 ); /* RSC Gate ON by TEST RSC No. */
	LD	E,16
