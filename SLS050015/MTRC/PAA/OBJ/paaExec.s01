	JR	NZ,?0074
?0073:
; 466.	                        io_output_on1( 0x1F );                  /* RSC Gate OFF */
	LD	E,31
	CALL	io_output_on1
; 467.	                        io_output_off2( 0x3F );                 /* All Speaker OFF */
	LD	E,63
	CALL	io_output_off2
; 468.	
; 469.	                        if( (nowReadIO & MICON)==0 ){           /* EMG Microphone InActive? */
	LD	HL,(nowReadIO)
	LD	A,L
	AND	32
	LD	B,A
	LD	A,H
	AND	0
	OR	B
	JR	NZ,?0076
?0075:
; 470.	                                testPhase++;
	LD	HL,testPhase
