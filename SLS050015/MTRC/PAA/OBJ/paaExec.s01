; 480.	                        }
; 481.	                        else {
	JR	?0081
?0080:
; 482.	                                io_output_off1( testTrouble );  /* RSC Gate ON by TEST RSC No. */
	LD	DE,(testTrouble)
	CALL	io_output_off1
?0081:
; 483.	                        }
; 484.	                        testCount = 0;
	LD	HL,0
	LD	(testCount),HL
; 485.	
; 486.	                        testPhase=2;
	LD	A,2
	LD	(testPhase),A
; 487.	                        return;
; 488.	                }
	JR	?0093
?0078:
; 489.	
; 490.	                if( testPhase==2 ){             /* ２秒間はチェックしない */
	LD	A,(testPhase)
	DEC	A
	DEC	A
	JR	NZ,?0083
?0082:
; 491.	                        if( testCount<200 ){            /* ２秒までは無視する */
	LD	BC,32968
	LD	HL,(testCount)
	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	NC,?0085
?0084:
; 492.	                                return;
; 493.	                        }
	JR	?0093
?0085:
; 494.	                        testPhase = 3;
	LD	A,3
	LD	(testPhase),A
; 495.	                        testCount = 0;
	LD	HL,0
	LD	(testCount),HL
?0083:
; 496.	                }
; 497.	                                                                /* マイクに音声が入ることを確認する */
; 498.	                if( nowReadIO & MICON ){                /* EMG Microphone Active? */
	LD	A,(nowReadIO)
