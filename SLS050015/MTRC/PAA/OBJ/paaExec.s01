	LD	A,128
	XOR	H
	LD	H,A
	SBC	HL,BC
	JR	C,?0089
?0088:
; 503.	                        testCount = 0;
	LD	HL,0
	LD	(testCount),HL
; 504.	                        if( testTrouble ){
	LD	A,(testTrouble)
	OR	A
	JR	Z,?0091
?0090:
; 505.	                                sendarea.trouble |= (testTrouble<<2);
	LD	A,(testTrouble)
	ADD	A,A
	ADD	A,A
	LD	B,A
	LD	A,(sendarea+4)
	OR	B
	LD	(sendarea+4),A
; 506.	                        }
; 507.	                        else {
	JR	?0092
?0091:
; 508.	                                testTrouble = 0x01<<testRSCNo;
	LD	A,(testRSCNo)
	LD	B,A
	LD	A,1
	CALL	?C_LSH_L01
	LD	(testTrouble),A
; 509.	                                sendarea.trouble &= ~(testTrouble<<2);
	ADD	A,A
	ADD	A,A
	CPL
	LD	B,A
	LD	A,(sendarea+4)
	AND	B
	LD	(sendarea+4),A
?0092:
; 510.	                        }
; 511.	                        testRSCNo++;
	LD	HL,testRSCNo
	INC	(HL)
?0089:
; 512.	                }
; 513.	}
?0093:
	POP	DE
	POP	BC
	RET
