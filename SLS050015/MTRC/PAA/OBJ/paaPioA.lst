     33    000000          ;*      Function name   << csio_initialize >>       
                                       *
     34    000000          ;*                      クロック同期式シリアルの初期
                           化                          *
     35    000000          ;*      Syntax          csio_initialize();          
                                               *
     36    000000          ;*      Argument        none                        
                                               *
     37    000000          ;*    Author    TOA Corporation   K.Honda
     38    000000          ;*    Revison   a00. 2000/06/26
     39    000000          ;*                                                  
                                               *
     40    000000          ;***************************************************
                           *********************/
     41    000000          ;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
                           ❺❺❺❺❺❺❺❺❺❺
     42    000000          ; ●クロック同期式シリアル出力の初期化を行う。
     43    000000          ;
     44    000000                  public  csio_initialize ;.(Function)
     45    000000          csio_initialize:
     46    000000 F5               push    af
     47    000001 E5               push    hl
     48    000002          
     49    000002 3E00             ld      a,00000000b
     50    000004 ED3953           out0    (DERA),a        ;. PA is ALL
                                                            I/O
     51    000007 3EA8             ld      a,10101000b
     52    000009 ED3970           out0    (DDRA),a                ;.
                                                                    TXS/CKS/TEN
                                                                   D1 is
                                                                    Output
     53    00000C 3EA8             ld      a,10101000b
     54    00000E 32....           ld      (csiodata),a
     55    000011 ED3960           out0    (ODRA),a                ;.
                                                                    TXS/CSK/TEN
                                                                   D1 is
                                                                    Initial
                                                                    High
     56    000014          
     57    000014 E1               pop     hl
     58    000015 F1               pop     af
     59    000016 C9               ret
     60    000017          
     61    000017          ;/**************************************************
                           *********************
     62    000017          ;*                                                  
                                               *
     63    000017          ;*      Function name   << csio_output >>           
                                       *
     64    000017          ;*                      クロック同期式シリアルの出力
                                               *
     65    000017          ;*      Syntax          csio_output( short data
                            );
     66    000017          ;*      Argument        none                        
                                               *
     67    000017          ;*    Author    TOA Corporation   K.Honda
     68    000017          ;*    Revison   a00. 2000/06/26
     69    000017          ;*                                                  
                                               *
     70    000017          ;***************************************************
                           *********************/
     71    000017          ;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
                           ❺❺❺❺❺❺❺❺❺❺
     72    000017          ;       data = reg.HL
     73    000017          ;
     74    000000                  public  csio_output     ;.(Function)
     75    000017          csio_output:
     76    000017 F5               push    af
     77    000018 C5               push    bc
     78    000019          
     79    000019 0E0D             ld              c,13
     80    00001B          csio_loop:
     81    00001B 7D               ld              a,l
     82    00001C E601             and             1
     83    00001E 2807             jr              z,csio_on
     84    000020          
     85    000020 3A....           ld              a,(csiodata)
     86    000023 E6F7             and             BINNOT 00001000b            
                                                       ; TXS ON
     87    000025 1805             jr              csio_onoff
     88    000027          csio_on:
     89    000027 3A....           ld              a,(csiodata)
     90    00002A F608             or              00001000b               ;
                                                    TXS OFF
     91    00002C          csio_onoff:
     92    00002C 32....           ld              (csiodata),a
     93    00002F ED3960           out0    (ODRA),a                ;. TXS
                                                                    SET
     94    000032          
     95    000032 3A....           ld              a,(csiodata)
     96    000035 E6DF             and             BINNOT 00100000b            
                                                       ; CXS OFF
     97    000037 32....           ld              (csiodata),a
     98    00003A ED3960           out0    (ODRA),a                ;. CXS
                                                                    SET
     99    00003D          
    100    00003D 3A....           ld              a,(csiodata)
    101    000040 F620             or              00100000b               ;
                                                    CXS ON
    102    000042 32....           ld              (csiodata),a
    103    000045 ED3960           out0    (ODRA),a                ;. CXS
                                                                    SET
    104    000048          
    105    000048 CB3C             srl             h                       ;
  Right Shift 1 bit
    106    00004A CB1D             rr              l
    107    00004C          
    108    00004C 0D               dec             c
    109    00004D 79               ld              a,c
    110    00004E B7               or              a
    111    00004F 20CA             jr              nz,csio_loop
    112    000051          
    113    000051 3A....           ld              a,(csiodata)
    114    000054 E67F             and             01111111b               ;
                                                    TEND1 OFF
    115    000056 32....           ld              (csiodata),a
    116    000059 ED3960           out0    (ODRA),a                ;. CXS
                                                                    SET
    117    00005C          
    118    00005C 3A....           ld              a,(csiodata)
    119    00005F F680             or              10000000b               ;
                                                    TEND1 ON
    120    000061 32....           ld              (csiodata),a
    121    000064 ED3960           out0    (ODRA),a                ;. CXS
                                                                    SET
    122    000067          
    123    000067 C1               pop     bc
    124    000068 F1               pop     af
    125    000069 C9               ret
    126    00006A          
