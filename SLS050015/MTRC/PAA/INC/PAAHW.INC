$.¥INC¥IO64180.INC


					;-- 外部ポートアドレス --
EXT_PORT0	equ	80h		; IN  b0-b4: 非常停止入力
						;        b5: EMG Microphone
						; OUT b0-b4: 非常通報装置音声入力ゲート
						;        b6: AMP LED
						;		 b7: RUN LED
EXT_PORT1	equ	81h		; IN  b0-b1: Noise Level
						;     b2-b3: AMP Output Confirm
						;        b4: Voice 24V
						;	  b5-b7: Address
						; OUT b0-b5: Speaker Output
						;     b6-b7: AMP Output
EXT_PORT2	equ	82h		; IN
						; OUT b0-b1: Noise Level ON
						;		 b7: Watch Dog Enable
EXT_PORT3	equ	83h		; OUT Debug LED

EXT_PORT7	equ	87h		; OUT Watch Dog Reset


TM0CNST		equ	3072		; 10msカウンタ値
TM1CNST		equ	307			;  1msカウンタ値
							; Φ=6.144MHz
							; Clock = 0.16276uS
							; TimeClock = 3.25521 uS
							; 10mS Count = 3072

					;-----	RAM領域		-----
RAMTOP		equ	0C000h		; RAM領域 先頭番地
RAMBOT		equ	0fdffh		; RAM領域 最終番地

