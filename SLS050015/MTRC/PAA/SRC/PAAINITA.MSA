;/***********************************************************************
;*									*
;*	Function name	<< ram_check >>				*
;*			ALL RAM Area read after write check
;*	Syntax		ram_check();			*
;*	Argument	return is OK, HALT is NG
;*	Author		TOA Corporation  K.Honda
;*	Revision	a00 2000/06/26 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
	public	ram_check		;.(Function)
ram_check:
	push	af

	ld		l,8
ram_check100:
	push	hl
	call	_Bankchange

	ld		ix,08000h
	ld		bc,04000h
ram_check200:
	ld		l,(ix+0)
	ld		(ix+0),055h
	nop
	nop
	nop
	ld		a,(ix+0)
	cp		055h
	jp		nz,ram_check900

	ld		(ix+0),l
	inc		ix
	dec		bc
	ld		a,b
	or		c
	jp		nz,ram_check200

	ld		ix,08000h
	ld		bc,04000h
ram_check300:
	ld		l,(ix+0)
	ld		(ix+0),0AAh
	nop
	nop
	nop
	ld		a,(ix+0)
	cp		0AAh
	jp		nz,ram_check900

	ld		(ix+0),l
	inc		ix
	dec		bc
	ld		a,b
	or		c
	jp		nz,ram_check300

	ld		ix,08000h
	ld		bc,04000h
ram_check400:
	ld		l,(ix+0)
	ld		(ix+0),0FFh
	nop
	nop
	nop
	ld		a,(ix+0)
	cp		0FFh
	jp		nz,ram_check900

	ld		(ix+0),l
	inc		ix
	dec		bc
	ld		a,b
	or		c
	jp		nz,ram_check400

	ld		ix,08000h
	ld		bc,04000h
ram_check500:
	ld		l,(ix+0)
	ld		(ix+0),000h
	nop
	nop
	nop
	ld		a,(ix+0)
	cp		000h
	jp		nz,ram_check900

	ld		(ix+0),l
	inc		ix
	dec		bc
	ld		a,b
	or		c
	jp		nz,ram_check500

	pop		hl
;;	inc		l
;;	ld		a,l
;;	cp		16
;;	jp		nz,ram_check100

	ld		hl,0

	pop		af
	ret

ram_check900:

	ld		hl,1

	pop		af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< rom_check >>				*
;*			ALL ROM Area Calc SUM
;*	Syntax		rom_check();			*
;*	Argument	Return is OK, NG is HALT
;*	Author		TOA Corporation  K.Honda
;*	Revision	a00 2000/06/26 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
	public	rom_check		;.(Function)
rom_check:
	push	af

	ld		h,0
	ld		l,0
rom_check100:
	push	hl
	call	_Bankchange

	ld		ix,08000h
	ld		bc,04000h
rom_check200:
	ld		a,h
	add		a,(ix+0)
	ld		h,a

	inc		ix
	dec		bc
	ld		a,b
	or		c
	jp		nz,rom_check200

	pop		hl
	inc		l
	ld		a,l
	cp		16
	jp		nz,rom_check100

	ld		a,h
	cp		000h
	jp		nz,rom_check900

	ld		hl,0

	pop		af
	ret

rom_check900:
	ld		hl,1

	pop		af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< HALTCPU >>				*
;*			HALT CPU 
;*	Syntax		HALTCPU();			*
;*	Argument	Return is OK, NG is HALT
;*	Author		TOA Corporation  K.Honda
;*	Revision	a00 2000/06/26 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
	public	HALTCPU		;.(Function)
HALTCPU:
	DI
	HALT

	END

