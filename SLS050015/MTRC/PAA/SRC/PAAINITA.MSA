	pop	af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< _Bankchange >>				*
;*			バンク切り換え					*
;*	Syntax		_Bankchange(bank_no);				*
;*	Argument	short	bank_no	i	:バンクＮｏ．		*
;*						 no       address	*
;*						  0 :  0000h -  3fffh	*
;*						  1 :  4000h -  7fffh	*
;*						  2 :  8000h -  bfffh	*
;*						  3 :  c000h -  ffffh	*
;*						  4 : 10000h - 13fffh	*
;*						  5 : 14000h - 17fffh	*
;*						  6 : 18000h - 1bfffh	*
;*						  7 : 1c000h - 1ffffh	*
;*						  8 : 20000h - 23fffh	*
;*						  9 : 24000h - 27fffh	*
;*						 10 : 28000h - 2bfffh	*
;*						 11 : 2c000h - 2ffffh	*
;*						 12 : 30000h - 33fffh	*
;*						 13 : 34000h - 37fffh	*
;*						 14 : 38000h - 3bfffh	*
;*						 15 : 3c000h - 3ffffh	*
;*	Author		TOA Corporation  K.Honda
;*	Revision	a00 2000/06/27 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・

	public	_Bankchange	;.(Function)
_Bankchange:
	push	af
	push	bc
	push	hl

	ld		b,0
	ld		c,l			;. ﾊﾞﾝｸNo.
	ld		hl,BBR_tbl		;. ﾊﾞﾝｸﾃ-ﾌﾞﾙADR.
	add		hl,bc
	ld		a,(hl)
	out0	(BBR),a			;. BBRｾｯﾄ

	pop	hl
	pop	bc
	pop	hl
	ret

BBR_tbl:				;. ﾊﾞﾝｸﾃ-ﾌﾞﾙ
	defb	0F8h		;. 0F8h+08h = 00h
	defb	0FCh		;. 0FCh+08h = 04h
	defb	000h		;. 000h+08h = 08h
	defb	004h		;. 004h+08h = 0Ch
	defb	008h		;. 008h+08h = 10h
	defb	00Ch		;. 00Ch+08h = 14h
	defb	010h		;. 010h+08h = 18h
	defb	014h		;. 014h+08h = 1Ch
	defb	018h		;. 018h+08h = 20h
	defb	01Ch		;. 01Ch+08h = 24h
	defb	020h		;. 020h+08h = 28h
	defb	024h		;. 024h+08h = 2Ch
	defb	028h		;. 028h+08h = 30h
	defb	02Ch		;. 02Ch+08h = 34h
	defb	030h		;. 030h+08h = 38h
	defb	034h		;. 034h+08h = 3Ch

