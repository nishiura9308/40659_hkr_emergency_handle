;/***********************************************************************
;*									*
;*	Function name	<< nmi_ir >>					*
;*			ＷＤＴ異常割り込み				*
;*	Syntax		nmi_intr();					*
;*	Argument	none						*
;*	Author		TOA Corporation  T.Takehisa			*
;*	Revision	a00 1993/04/30 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; nmi_intr_routine を呼び出す。
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
;;	extern	nmi_intr_routine
nmi_ir:
	push	af
	push	bc
	push	de
	push	hl
	push	ix
	push	iy
	
	
;;	call	nmi_intr_routine
	ld	a, c
	cp	1
	jp	nz, nmi_ir_999
							;. Ｓ／Ｗリセット
	ld	hl, 0
	push	hl
	retn

nmi_ir_999:						;. 通常復帰
	pop	iy
	pop	ix
	pop	hl
	pop	de
	pop	bc
	pop	af
	retn


	page
