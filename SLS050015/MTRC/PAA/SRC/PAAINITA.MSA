;/***********************************************************************
;*									*
;*	Function name	<< BOOTSTRUP >>					*
;*			ＣＰＵ起動処理					*
;*	Syntax		BUUOSTRUP();					*
;*	Argument	none						*
;*	Author		TOA Corporation  t.takehisa			*
;*	Revision	a00 1993/09/07 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; ＣＰＵ起動処理。
;   ダミーＲＥＴＩ命令発効。
;　 ＣＰＵ及び周辺の初期化。
;   ソフトウェア（変数、バンクＲＡＭ等）イニシャライズ。
;   Ｃのプログラムへジャンプ。
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
	extern	main				;.(Function) Ｓ／Ｗメイン制御

BOOTSTRUP:
	ld	sp,RAMBOT+30
	nop
	nop
	nop
	nop
	nop
	nop
	nop
	nop
	nop
	nop
	;.**********************************
	;.	ＣＰＵごまかし処理
	;.**********************************
	ld	hl, BOOTSTRUP10
	push	hl
	reti
BOOTSTRUP10:
	ld	hl, BOOTSTRUP11
	push	hl
	reti
BOOTSTRUP11:
	ld	hl, BOOTSTRUP12
	push	hl
	reti
BOOTSTRUP12:
	ld	hl, BOOTSTRUP13
	push	hl
	reti
BOOTSTRUP13:
	ld	hl, BOOTSTRUP14
	push	hl
	reti
BOOTSTRUP14:
	ld	hl, BOOTSTRUP15
	push	hl
	reti
BOOTSTRUP15:
	ld	hl, BOOTSTRUP16
	push	hl
	reti
BOOTSTRUP16:

	nop
	nop
	nop

	ld	sp,RAMBOT +30

;/***********************************************************************
;*									*
;*	Function name	<< x180_init >>					*
;*			ＩＣ初期化処理					*
;*	Syntax		x180_init();					*
;*	Argument	none						*
;*	Author		TOA Corporation  h.nisiura			*
;*	Revision	a00 1995/12/05 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
; Ｈ／Ｗ（ＣＰＵ）を初期化する。
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
x180_init:
	di
	;.・・・・・・・・・・・・・・・・・・・・・
	;.　Ｉﾚｼﾞｽﾀを00hにする
	;.・・・・・・・・・・・・・・・・・・・・・
					;. ----- 初期化開始 -----
	ld	a,00h
	ld	i,a			;. 割込ベクタレジスタ

	;・・・・・・・・・・・・・・・・・・・・・
	; I/O , REF, INT  の初期化
	;・・・・・・・・・・・・・・・・・・・・・
	;　I/Oｺﾝﾄﾛｰﾙ･ﾚｼﾞｽﾀ　     =  0h
	;　ﾘﾌﾚｯｼｭ･ｺﾝﾄﾛｰﾙ･ﾚｼﾞｽﾀ   =  0h
	;  ｲﾝﾀﾗﾌﾟﾄ･ﾍﾞｸﾀ･ﾛｰ･ﾚｼﾞｽﾀ = 40h
	;  INT/TRAPｺﾝﾄﾛｰﾙ･ﾚｼﾞｽﾀ  = 02h
	;・・・・・・・・・・・・・・・・・・・・・
	ld	a,0
	out0	(ICR),a			;. I/O コントロールレジスタ
	out0	(RCR),a			;. リフレッシュコントロールレジスタ
	ld	a,40h			;. 割込ベクタ ローレジスタ
	out0	(IL),a
	ld	a,02h			;. INT/TRAP control register
	out0	(ITC),a			;. INT0=off, INT1=on, INT2=off

	;・・・・・・・・・・・・・・・・・・・・・
	; ＭＭＵ設定
	;・・・・・・・・・・・・・・・・・・・・・
	;      論理ﾒﾓﾘ空間マッピング図   ・ ＭＭＵﾚｼﾞｽﾀ設定
	;・・・・・・・・・・・・・・・・・・・・・
	; FFFFh・・・・・・・・          ・・CBR ・・・・ 
	;      ・Program   ・ 16 K bytes ・・14h(20000)・     CBR  = 14h
	;      ・    RAM   ・            ・・・・・・・・ 
	; C000h・・・・・・・・          ・・BBR ・・・・ 
	; ￣*2                             ・00h(08000)・     BBR  = 00h
	;      ・          ・            ・・・・・・・・ 
	;      ・          ・            ・・CBAR・・・・ 
	;      ・          ・              ・*2  ・*1  ・ 
	;      ・          ・            ・・  Ch・  8h・     CBAR = C8h
	;      ・・・・・・・・          ・・・・・・・・ 
	;      ・          ・            ・
	;      ・Bank  RAM ・ 16 K bytes ・
	; 8000h・・・・・・・・          ・
	; ￣*1 ・          ・            ・
	;      ・          ・            ・
	;      ・          ・            ・
	;      ・          ・            ・
	;      ・          ・ 32 K bytes ・
	;      ・Program   ・            ・
	;      ・    ROM   ・            ・
	; 0000h・・・・・・・・          ・
	;・・・・・・・・・・・・・・・・・・・・・
	ld	a, 0C8h			;. 0000h～7FFFh	コモンエリア０	00000h-07FFFh
						;. 8000h～BFFFh	バンクエリア	08000h-0BFFFh
						;. C000h～FFFFh	コモンエリア１	20000h-23FFFh
	out0	(CBAR), a		;. ＭＭＵコモン／バンク・エリアレジスタ
	ld	a, 014h			;. コモンエリア１物理アドレス 20000h
	out0	(CBR), a		;. ＭＭＵコモン・ベース・レジスタ
	ld	a, 000h			;. バンクエリア　物理アドレス 08000h
	out0	(BBR), a		;. ＭＭＵバンク・ベース・レジスタ

	call	init_ic			;. ＩＣ初期化処理

	im 	1			;. 割込モード  1
					;. ----- 初期化終了 -----

	jp	main			;. Jump to Main Module( C language )


;/***********************************************************************
;*									*
;*	Function name	<< init_ic >>					*
;*			ＩＣの初期化					*
;*	Syntax		init_ic();					*
;*	Argument	None						*
;*	Author		TOA Corporation  T.Takehisa			*
;*	Revision	a00 1993/09/07 					*
;*									*
;************************************************************************/
	extern	timer_0_initialize
	extern	timer_1_initialize
	extern	asci_0_initialize
	extern	csio_initialize
	public	init_ic				;.(Function)
init_ic:
;.・・・・・・・・・・・・・・・・・・・・・
; ＣＰＵ内蔵ペリフェラル、外部IC初期化
;.・・・・・・・・・・・・・・・・・・・・・
	push	af
	push	bc
	push	de
	push	hl
	push	ix
	push	iy
	
	call	timer_0_initialize	;. TIMER 0 初期化
	call	timer_1_initialize	;. TIMER 1 初期化
	call	asci_0_initialize	;. ASCI  0 初期化
	call	csio_initialize		;. CSI/O 初期化

	pop	iy
	pop	ix
	pop	hl
	pop	de
	pop	bc
	pop	af
	ret


;/***********************************************************************
;*									*
;*	Function name	<< read_dipsw >>				*
;*			jumper Switch Read
;*	Syntax		reg.C = read_dipsw();			*
;*	Argument	Reg. BC		o: Switch Data		*
;*	Author		TOA Corporation  K.Honda
;*	Revision	a00 2000/06/26 					*
;*									*
;************************************************************************/
;.・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・・
	public	read_dipsw		;.(Function)
read_dipsw:
	push	af

	in0	a, (IDRG)		;. Read Dipsw
	and	0Fh
	ld	l,a
	ld	h, 0

	pop	af
	ret

