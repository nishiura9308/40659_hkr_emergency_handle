;*	Argument	char ondata4 	o ： Set data of Port4						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	ondata4 =
;.		b0...b7 = Debug LED
;
	public	io_output_on4	;.(Function)
io_output_on4:
	push	af

	ld		a,(iodata+3)
	or		E
	ld		(iodata+3),a
	out0	(EXT_PORT3),a

	pop	af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< io_output_off1 >>			*
;*			Ｉ／Ｏ出力のＯＦＦ処理
;*	Syntax		io_output_off1( offdata1 );
;*	Argument	char offdata1	i ： Set OFF data of Port0						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	offdata1 =
;.		b0...b4 = EMG Microphone Gate
;.		b6 = AMP LED
;.		b7 = RUN LED

	public	io_output_off1	;.(Function)
io_output_off1:
	push	af

	ld		a,E
	CPL
	ld		E,A
	ld		a,(iodata)
	AND		E
	ld		(iodata),a
	out0	(EXT_PORT0),a

	pop	af
	ret

