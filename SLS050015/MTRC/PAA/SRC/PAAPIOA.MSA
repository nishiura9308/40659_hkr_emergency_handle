	module	'香港地下鉄 AAU PAA S/W'
$.¥INC¥PAAHW.INC

;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	データ
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
	RSEG	RDATA :DATA

public iodata
iodata:
	defs	4

csiodata:
	defs	1

;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	プログラム部
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
	RSEG	RCODE :CODE

;/***********************************************************************
;*									*
;*	Function name	<< csio_initialize >>			*
;*			クロック同期式シリアルの初期化				*
;*	Syntax		csio_initialize();				*
;*	Argument	none						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
; ●クロック同期式シリアル出力の初期化を行う。
;
	public	csio_initialize	;.(Function)
csio_initialize:
	push	af
	push	hl

	ld	a,00000000b
	out0	(DERA),a	;. PA is ALL I/O
	ld	a,10101000b
	out0	(DDRA),a		;. TXS/CKS/TEND1 is Output
	ld	a,10101000b
	ld	(csiodata),a
	out0	(ODRA),a		;. TXS/CSK/TEND1 is Initial High

	pop	hl
	pop	af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< csio_output >>			*
;*			クロック同期式シリアルの出力			*
;*	Syntax		csio_output( data );
;*	Argument	short data    i ：　Output Data.						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;	data = reg.HL
;
	public	csio_output	;.(Function)
csio_output:
	push	af
	push	bc

	ld		c,13
csio_loop:
	ld		a,l
	and		1
	jr		z,csio_on

	ld		a,(csiodata)
	and		BINNOT 00001000b		; TXS ON
	jr		csio_onoff
csio_on:
	ld		a,(csiodata)
	or		00001000b		; TXS OFF
csio_onoff:
	ld		(csiodata),a
	out0	(ODRA),a		;. TXS SET

	ld		a,(csiodata)
	and		BINNOT 00100000b		; CXS OFF
	ld		(csiodata),a
	out0	(ODRA),a		;. CXS SET

	ld		a,(csiodata)
	or		00100000b		; CXS ON
	ld		(csiodata),a
	out0	(ODRA),a		;. CXS SET

	srl		h			; Right Shift 1 bit
	rr		l

	dec		c
	ld		a,c
	or		a
	jr		nz,csio_loop

	ld		a,(csiodata)
	and		01111111b		; TEND1 OFF
	ld		(csiodata),a
	out0	(ODRA),a		;. CXS SET

	ld		a,(csiodata)
	or		10000000b		; TEND1 ON
	ld		(csiodata),a
	out0	(ODRA),a		;. CXS SET

	pop	bc
	pop	af
	ret



;/***********************************************************************
;*									*
;*	Function name	<< switch_read >>			*
;*			スイッチ情報の読み込み
;*	Syntax		r=switch_read( void );
;*	Argument	short r	  o	:　Import Switch data						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;	output Reg.HL
;
	public	switch_read	;.(Function)
switch_read:
	push	af

	in0		a,(EXT_PORT0)
	ld		l,a
	in0		a,(EXT_PORT1)
	ld		h,a

	pop	af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< io_output_on1 >>			*
;*			Ｉ／Ｏ出力のＯＮ処理
;*	Syntax		io_output_on1( ondata1 );
;*	Argument	char ondata1	o ： Set data of Port0						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	ondata1 =
;.		b0...b4 = EMG Microphone Gate
;.		b6 = AMP LED
;.		b7 = RUN LED
;
	public	io_output_on1	;.(Function)
io_output_on1:
	push	af

	ld		a,(iodata)
	or		E
	ld		(iodata),a
	out0	(EXT_PORT0),a

	pop	af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< io_output_on2 >>			*
;*			Ｉ／Ｏ出力のＯＮ処理
;*	Syntax		io_output_on2( ondata2 );
;*	Argument	char ondata2 	o ： Set data of Port1						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	ondata2 =
;.		b0...b5 = Speaker ON
;.		b6...b7 = AMP ON
;
	public	io_output_on2	;.(Function)
io_output_on2:
	push	af

	ld		a,(iodata+1)
	or		E
	ld		(iodata+1),a
	out0	(EXT_PORT1),a

	pop	af
	ret

;/***********************************************************************
;*									*
;*	Function name	<< io_output_on3 >>			*
;*			Ｉ／Ｏ出力のＯＮ処理
;*	Syntax		io_output_on3( ondata3 );
;*	Argument	char ondata3 	o ： Set data of Port3						*
;*    Author	TOA Corporation   K.Honda
;*    Revison	a00. 2000/06/26
;*									*
;************************************************************************/
;.❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺❺
;.	ondata3 =
;.		b0...b1 = Noise Level ON
;.		b7 = Watch Dog Enable
;
	public	io_output_on3	;.(Function)
io_output_on3:
	push	af

	ld		A,(iodata+2)
	or		E
	ld		(iodata+2),a
	out0	(EXT_PORT2),a

	pop	af
	ret

