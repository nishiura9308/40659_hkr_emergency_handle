                  1258:    /************************************************************************
                  1259:    
                  1260:            Function name   << dvaAUTO >>
                  1261:                                            自動放送シーケンス処理
                  1262:            Syntax                  dvaAUTO( void );
                  1263:            Argument                none
                  1264:            Author                  TOA Corporation  K.Honda
                  1265:            Revision                a00 2000/08/07
                  1266:                                    a01 2001/03/22  スピーカー制御
                  1267:                                    a02 2001/07/02  自動放送モードへ戻るフラグのセット
                  1268:                                    a03 2001/07/10  EIDS Door Status is TMS Data
                  1269:                                                                    EIDS Reset 信号がアクティブのときは、
