                  2506:    /*. --------------------------【機能詳細】----------------------------[@@@S]
                  2507:    
                  2508:            処理概要：
                  2509:                    １６両編成で、音声バス通信が異常になったとき、
                  2510:                    自ＤＶＡＵのＨＣＲがＯＦＦであれば、
                  2511:                    スタンバイモードに移行する
                  2512:    
                  2513:            ------------------------------------------------------------------[@@@E]*/
                  2514:    void dvaCOUPLING( void )
    002E7A              _dvaCOUPLING:                    ; function: dvaCOUPLING
                  2515:    {
                  2516:    
                  2517:                                                                                                    // 2004/09/13   h.nishiura
                  2518:                    if( nowSignal.SIGNAL2.RBIT.hcrON==0 ){
    002E7A 6A2800                 MOV.B       @_nowSignal+1:24,R0L
           <000000>     
    002E80 7708                   BLD.B       #0,R0L
    002E82 450A                   BCS         L860:8
                  2519:                            dvaIOOut(
                  2520:                                    0
                  2521:                                    ,
                  2522:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2523:                                    | OUTSIGNAL_commDummyOFF                        // １６両編成通信用ダミー抵抗ＯＮ
                  2524:                            );
