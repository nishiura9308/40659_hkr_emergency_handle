                  2499:    /************************************************************************
                  2500:    
                  2501:            Function name   << dvaCOUPLING >>
                  2502:                                            １６両編成チェック処理
                  2503:            Syntax                  dvaCOUPLING( void );
                  2504:            Argument                none
                  2505:            Author                  TOA Corporation  K.Honda
                  2506:            Revision                a00 2000/08/07
                  2507:                                            a01 2000/10/10  通信手順変更
                  2508:                                            a02 2004/09/13  h.nishiura
                  2509:                                                                            常にcommGateオープン
                  2510:                                                                            HCR ONと連動してダミー抵抗ＯＮに変更
                  2511:    *************************************************************************/
                  2512:    /*. --------------------------【機能詳細】----------------------------[@@@S]
                  2513:    
                  2514:            処理概要：
                  2515:                    １６両編成で、音声バス通信が異常になったとき、
                  2516:                    自ＤＶＡＵのＨＣＲがＯＦＦであれば、
                  2517:                    スタンバイモードに移行する
                  2518:    
                  2519:            ------------------------------------------------------------------[@@@E]*/
                  2520:    void dvaCOUPLING( void )
    002F00              _dvaCOUPLING:                    ; function: dvaCOUPLING
                  2521:    {
                  2522:    
                  2523:                                                                                                    // 2004/09/13   h.nishiura
                  2524:                    if( nowSignal.SIGNAL2.RBIT.hcrON==0 ){
    002F00 6A2800                 MOV.B       @_nowSignal+1:24,R0L
           <000000>     
    002F06 7708                   BLD.B       #0,R0L
    002F08 450A                   BCS         L860:8
                  2525:                            dvaIOOut(
                  2526:                                    0
                  2527:                                    ,
                  2528:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2529:                                    | OUTSIGNAL_commDummyOFF                        // １６両編成通信用ダミー抵抗ＯＮ
                  2530:                            );
    002F0A 1A91                   SUB.L       ER1,ER1
    002F0C F1A0                   MOV.B       #-96:8,R1H
    002F0E 1A80                   SUB.L       ER0,ER0
    002F10 5A                     JMP         @_dvaIOOut:24
           <000000>     
    002F14              L860:                             
                  2531:                    }else{
                  2532:                            dvaIOOut(
                  2533:                                    OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2534:                                    ,
                  2535:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2536:                            );
    002F14 1A91                   SUB.L       ER1,ER1
    002F16 F180                   MOV.B       #-128:8,R1H
    002F18 1A80                   SUB.L       ER0,ER0
    002F1A F020                   MOV.B       #32:8,R0H
    002F1C 5A                     JMP         @_dvaIOOut:24
           <000000>     
                  2537:                    }
                  2538:                    return;
                  2539:                                                                                                    // 2004/09/13   h.nishiura 以下は処理しない
                  2540:    
                  2541:                    if( DUALPORT.activeDVAU==0 ){           // 非アクティブＤＶＡＵは
                  2542:    
                  2543:                            timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2544:    
                  2545:                            if( DUALPORT.couplingCheck==4 ){                        // １６両編成中は
                  2546:                                    dvaIOOut(
                  2547:                                            OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2548:                                            ,
                  2549:                                            OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＦＦ
                  2550:                                    );
                  2551:                                    return;
                  2552:                            }
                  2553:    
                  2554:                            DUALPORT.couplingCheck = 0;             // 連結チェックなし
                  2555:                            dvaIOOut(
                  2556:                                    0
                  2557:                                    ,
                  2558:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2559:                                    | OUTSIGNAL_commDummyOFF                        // １６両編成通信用ダミー抵抗ＯＮ
                  2560:                            );
                  2561:                            return;
                  2562:                    }
                  2563:    
                  2564:                            // 連結チェックタイミング
                  2565:    
                  2566:                    switch( DUALPORT.couplingCheck ){
                  2567:                    case 0:         // 連結チェック開始
                  2568:                            // アクティブＤＶＡＵは１分間通常通信をおこなう
                  2569:                            if( timedata.commGateTimer ){
                  2570:                                    DUALPORT.couplingCheck = 0;             // 連結チェックなし
                  2571:                                    dvaIOOut(
                  2572:                                            OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2573:                                            | OUTSIGNAL_commGateOFF                 // １６両編成通信用ゲートＯＦＦ
                  2574:                                            ,
                  2575:                                            0
                  2576:                                    );
                  2577:                                    return;
                  2578:                            }
                  2579:    
                  2580:                            // ファイルを更新中のときは連結チェックしない
                  2581:                            if( DUALPORT.download_active ){
                  2582:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2583:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2584:                                    return;
                  2585:                            }
                  2586:                            if( DUALPORT.upload_active ){
                  2587:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2588:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2589:                                    return;
                  2590:                            }
                  2591:    
                  2592:    
                  2593:                            // ＨＣＲがＯＦＦのときはチェックしない
                  2594:                            if( nowSignal.SIGNAL2.RBIT.hcrON==0 ){
                  2595:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2596:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2597:                                    return;
                  2598:                            }
                  2599:    
                  2600:                            // アイドルモードか自動放送中のみ受け付け
                  2601:                            if( backup_data.opeMode!=OPEMODE_IDLE && backup_data.opeMode!=OPEMODE_AUTO ){
                  2602:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2603:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2604:                                    return;
                  2605:                            }
                  2606:    
                  2607:    
                  2608:    //                      if( P4.DR.BIT.B3==0 ){
                  2609:    //                              return;         // １６両編成チェックをやめる
                  2610:    //                      }
                  2611:    
                  2612:                            DUALPORT.couplingCheck = 1;             // 連結チェックをサブＣＰＵへ通知
                  2613:                            break;
                  2614:    
                  2615:                    case 1:         // 連結チェック開始確認中
                  2616:                            break;
                  2617:    
                  2618:                    case 2:         // 連結チェック起動確認中
                  2619:                            // アクティブＤＶＡＵは
                  2620:                            dvaIOOut(
                  2621:                                    OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2622:                                    ,
                  2623:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2624:                            );
                  2625:                            break;
                  2626:    
                  2627:                    case 3:         // 連結なし応答
                  2628:                            dvaIOOut(
                  2629:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＦＦ
                  2630:                                    | OUTSIGNAL_commDummyOFF                        // １６両編成通信用ダミー抵抗ＯＦＦ
                  2631:                                    ,
                  2632:                                    0
                  2633:                            );
                  2634:    
                  2635:                            DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2636:                            timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2637:                            break;
                  2638:    
                  2639:                    case 4:         // 連結あり応答
                  2640:                            dvaIOOut(
                  2641:                                    OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2642:                                    ,
                  2643:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＦＦ
                  2644:                            );
                  2645:                            timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2646:                            break;
                  2647:                    }
                  2648:    }
