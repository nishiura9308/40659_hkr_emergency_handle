                  2533:                                                                                                    // 2004/09/13   h.nishiura 以下は処理しない
                  2534:    
                  2535:                    if( DUALPORT.activeDVAU==0 ){           // 非アクティブＤＶＡＵは
                  2536:    
                  2537:                            timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2538:    
                  2539:                            if( DUALPORT.couplingCheck==4 ){                        // １６両編成中は
                  2540:                                    dvaIOOut(
                  2541:                                            OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2542:                                            ,
                  2543:                                            OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＦＦ
                  2544:                                    );
                  2545:                                    return;
                  2546:                            }
                  2547:    
                  2548:                            DUALPORT.couplingCheck = 0;             // 連結チェックなし
                  2549:                            dvaIOOut(
                  2550:                                    0
                  2551:                                    ,
                  2552:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2553:                                    | OUTSIGNAL_commDummyOFF                        // １６両編成通信用ダミー抵抗ＯＮ
                  2554:                            );
                  2555:                            return;
                  2556:                    }
                  2557:    
                  2558:                            // 連結チェックタイミング
                  2559:    
                  2560:                    switch( DUALPORT.couplingCheck ){
                  2561:                    case 0:         // 連結チェック開始
                  2562:                            // アクティブＤＶＡＵは１分間通常通信をおこなう
                  2563:                            if( timedata.commGateTimer ){
                  2564:                                    DUALPORT.couplingCheck = 0;             // 連結チェックなし
                  2565:                                    dvaIOOut(
                  2566:                                            OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2567:                                            | OUTSIGNAL_commGateOFF                 // １６両編成通信用ゲートＯＦＦ
                  2568:                                            ,
                  2569:                                            0
                  2570:                                    );
                  2571:                                    return;
                  2572:                            }
                  2573:    
                  2574:                            // ファイルを更新中のときは連結チェックしない
                  2575:                            if( DUALPORT.download_active ){
                  2576:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2577:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2578:                                    return;
                  2579:                            }
                  2580:                            if( DUALPORT.upload_active ){
                  2581:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2582:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2583:                                    return;
                  2584:                            }
                  2585:    
                  2586:    
                  2587:                            // ＨＣＲがＯＦＦのときはチェックしない
                  2588:                            if( nowSignal.SIGNAL2.RBIT.hcrON==0 ){
                  2589:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2590:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2591:                                    return;
                  2592:                            }
                  2593:    
                  2594:                            // アイドルモードか自動放送中のみ受け付け
                  2595:                            if( backup_data.opeMode!=OPEMODE_IDLE && backup_data.opeMode!=OPEMODE_AUTO ){
                  2596:                                    DUALPORT.couplingCheck = 0;             // 連結チェック終了
                  2597:                                    timedata.commGateTimer = 6000;  // 通信ゲートオープンタイマー起動
                  2598:                                    return;
                  2599:                            }
                  2600:    
                  2601:    
                  2602:    //                      if( P4.DR.BIT.B3==0 ){
                  2603:    //                              return;         // １６両編成チェックをやめる
                  2604:    //                      }
                  2605:    
                  2606:                            DUALPORT.couplingCheck = 1;             // 連結チェックをサブＣＰＵへ通知
                  2607:                            break;
                  2608:    
                  2609:                    case 1:         // 連結チェック開始確認中
                  2610:                            break;
                  2611:    
                  2612:                    case 2:         // 連結チェック起動確認中
                  2613:                            // アクティブＤＶＡＵは
                  2614:                            dvaIOOut(
                  2615:                                    OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2616:                                    ,
                  2617:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
                  2618:                            );
                  2619:                            break;
                  2620:    
                  2621:                    case 3:         // 連結なし応答
