                  2525:                    }else{
                  2526:                            dvaIOOut(
                  2527:                                    OUTSIGNAL_commDummyOFF                  // １６両編成通信用ダミー抵抗ＯＦＦ
                  2528:                                    ,
                  2529:                                    OUTSIGNAL_commGateOFF                   // １６両編成通信用ゲートＯＮ
