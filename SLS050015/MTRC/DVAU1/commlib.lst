                   273:    /************************************************************************
                   274:    
                   275:            Function name   << asci_0_Initialize >>
                   276:                                            初期設定
                   277:            Syntax                  asci_0_Initialize( baud, data, parity, stop );
                   278:            Argument                int baud   : i : ボーレート 1200-9600
                   279:                                    int data   : i : データ長　8 or 7
                   280:                                    int parity : i : パリティー 'E'=Even, 'O'=Odd, 'N'=None
                   281:                                    int stop   : i : ストップ長　0 or 1
                   282:            Author                  TOA Corporation  K.Honda
                   283:            Revision                a00 2000/07/27
                   284:    
                   285:    *************************************************************************/
                   286:    void asci_0_Initialize( int baud, char data, char parity, char stop )
    0000CC              _asci_0_Initialize:              ; function: asci_0_Initialize
    0000CC 5E                     JSR         @$sp_regsv$3:24
           <000000>     
                   287:    {
    0000D0 0D06                   MOV.W       R0,R6
                   288:    /*. --------------------------【機能詳細】----------------------------[@@@S]
                   289:    　・非同期　ＣＨ．０の初期設定
                   290:            ------------------------------------------------------------------[@@@E]*/
                   291:                    SCI0.SMR.BYTE = 0;
    0000D2 18AA                   SUB.B       R2L,R2L
    0000D4 3AB0                   MOV.B       R2L,@16777136:8
                   292:                    SCI0.SMR.BIT.CA   = 0;  /* 調歩同期 */
    0000D6 7FB07270               BCLR.B      #7,@16777136:8
                   293:                    if( data==8 ){
    0000DA A908                   CMP.B       #8:8,R1L
    0000DC 4606                   BNE         L177:8
                   294:                            SCI0.SMR.BIT.CHR  = 0;  /* 8bit data */
    0000DE 7FB07260               BCLR.B      #6,@16777136:8
    0000E2 4004                   BRA         L178:8
    0000E4              L177:                             
                   295:                    }
                   296:                    else {
                   297:                            SCI0.SMR.BIT.CHR  = 1;  /* 7bit data */
    0000E4 7FB07060               BSET.B      #6,@16777136:8
    0000E8              L178:                             
                   298:                    }
                   299:                    if( parity=='E' ){
    0000E8 A145                   CMP.B       #69:8,R1H
    0000EA 460A                   BNE         L179:8
                   300:                            SCI0.SMR.BIT.PE   = 1;  /* Even Parity */
    0000EC 7FB07050               BSET.B      #5,@16777136:8
                   301:                            SCI0.SMR.BIT.OE   = 0;
    0000F0 7FB07240               BCLR.B      #4,@16777136:8
    0000F4 4012                   BRA         L180:8
    0000F6              L179:                             
                   302:                    }
                   303:                    else if( parity=='O' ){
    0000F6 A14F                   CMP.B       #79:8,R1H
    0000F8 460A                   BNE         L181:8
                   304:                            SCI0.SMR.BIT.PE   = 1;  /* Odd Parity */
    0000FA 7FB07050               BSET.B      #5,@16777136:8
                   305:                            SCI0.SMR.BIT.OE   = 1;
    0000FE 7FB07040               BSET.B      #4,@16777136:8
    000102 4004                   BRA         L182:8
    000104              L181:                             
                   306:                    }
                   307:                    else {
                   308:                            SCI0.SMR.BIT.PE   = 0;  /* Non Parity */
    000104 7FB07250               BCLR.B      #5,@16777136:8
    000108              L182:                             
    000108              L180:                             
                   309:                    }
                   310:                    if( stop==0 ){
    000108 6E780019               MOV.B       @(25:16,SP),R0L
    00010C 4606                   BNE         L183:8
                   311:                            SCI0.SMR.BIT.STOP = 0;  /* 1 Stop Bit */
    00010E 7FB07230               BCLR.B      #3,@16777136:8
    000112 4004                   BRA         L184:8
    000114              L183:                             
                   312:                    }
                   313:                    else {
                   314:                            SCI0.SMR.BIT.STOP = 1;  /* 2 Stop Bit */
    000114 7FB07030               BSET.B      #3,@16777136:8
