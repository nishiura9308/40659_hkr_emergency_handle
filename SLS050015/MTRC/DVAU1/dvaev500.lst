                    46:    #define SEND_ABORT_RECV         13              // 放送キャンセル受信
                    47:    #define SEND_ABORTBUSY          14      // 放送キャンセル終了
                    48:    #define SEND_ABORTBUSY_RECV     15      // 放送キャンセル終了待ち
                    49:    #define SEND_TIME_GET           16              // 日時要求
