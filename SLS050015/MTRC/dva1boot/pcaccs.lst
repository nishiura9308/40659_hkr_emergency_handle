                    33:    *******************************************************************/
                    34:    
                    35:    /***************************************************************************
                    36:    
                    37:            CE2#    CE1#    A0              Offset  Data Bus
                    38:    *        L               L              L               0H,8H   D15-D0          Word Data
                    39:    *        L               L              H               1H,9H   D15-D0          Word Data
                    40:             H               L              L               0H,8H   D7-D0           Even Byte Data
                    41:             H               L              H               9H              D7-D0           Odd Byte Data
                    42:    *        L               H              X               8H,9H   D15-D8          Odd Byte Data
                    43:             H               L              H               1H,0Dh  D7-D0           Error/Feature 
                    44:    *        L               H              X               0H,1H   D15-D8          Error/Feature
                    45:    *        L               L              X               0CH,0DH D15-D8          Error/Feature
                    46:    
                    47:                            * = This Board is Not used
                    48:    
                    49:            I/O Mapped Addressing
                    50:    
                    51:                                    Primary Secondary       Contiguous      IORD#=0                 IOWR#=0
                    52:                    REG#    A9::0   A9::0                   A3::0
                    53:                     L              1F0h    170h                    0h              Even Read Data  Even Write Data
                    54:                     L              1F1h    171h                    1h              Error Register  Feature
                    55:                     L              1F2h    172h                    2h              Sector Count    Sector Count
                    56:                     L              1F3h    173h                    3h              Sector Number   Sector Number
                    57:                     L              1F4h    174h                    4h              Cylinder Low    Cylinder Low
                    58:                     L              1F5h    175h                    5h              Cylinder High   Cylinder High
                    59:                     L              1F6h    176h                    6h              Drive/Head              Drive/Head
                    60:                     L              1F7h    177h                    7h              Status                  Command
                    61:                     L              ---             ---                             8h              Duplicate               Duplicate
                    62:                                                                                                    Even Read Data  Even Write Data
                    63:                     L              ---             ---                             9h              Duplicate               Duplicate
                    64:                                                                                                    Odd Read Data   Odd Write Data
                    65:                     L              ---             ---                             0Dh             Duplicate Error Duplicate Feature
                    66:                     L              3F6h    376h                    0Eh             Alternate Status Device Control
                    67:                     L              3F7h    377h                    0Fh             Drive Address   Reserved
                    68:    
                    69:    
                    70:            Memory Mapped
                    71:                    REG#    A10     A9::4   A3      A2      A1      A0              OE#=0                   WE#=0
                    72:                     H               L         X    L       L       L       L               Read Data               Write Data
                    73:                     H               L         X    L       L       L       H               Error                   Feature
                    74:                     H               L         X    L       L       H       L               Sector Count    Sector Count
                    75:                     H               L         X    L       L       H       H               Sector Number   Sector Number
                    76:                     H               L         X    L       H       L       L               Cylinder Low    Cylynder Low
                    77:                     H               L         X    L       H       L       H               Cylinder High   Cylynder High
                    78:                     H               L         X    L       H       H       L               Drive/Head              Drive/Head
                    79:                     H               L         X    L       H       H       H               Status                  Command
                    80:                     H               L         X    H       L       L       L               Duplicate Even  Duplicate Even
                    81:                                                                                                    Read Data               Write Data
                    82:                     H               L         X    H       L       L       H               Duplicate Odd   Duplicate Odd
                    83:                                                                                                    Read Data               Write Data
                    84:                     H               L         X    H       L       H       L               
                    85:                     H               L         X    H       L       H       H               
                    86:                     H               L         X    H       H       L       L
                    87:                     H               L         X    H       H       L       H
                    88:                     H               L         X    H       H       H       L               Alt Status              Device Ctl
                    89:                     H               L         X    H       H       H       H               Drive Address   Reserved
                    90:    
                    91:                     H               H         X    X       X       X       L               Even Read Data  Even Write Data
                    92:                     H               H         X    X       X       X       H               Odd Read Data   Odd Write Data
                    93:    
                    94:    
                    95:    
                    96:            Command Block Cylinder-Head-Sector Addressing
                    97:    
                    98:                    +1      Feautre
                    99:                    +2      Sector Count
                   100:                    +3      Sector Number
                   101:                    +4      Cylinder Low
                   102:                    +5      Cylinder High
                   103:                    +6      101<Drv><Head>
                   104:                    +7      Command
                   105:    
                   106:            Command Block Logical Block Addressing
                   107:            
                   108:                    +1      Feature
                   109:                    +2      Sector Count
                   110:                    +3      LBN A7-A0
                   111:                    +4      LBN A15-A8
                   112:                    +5      LBN     A23-A16
                   113:                    +6      111<Drv><LBN A27-A24>
                   114:                    +7      Command
                   115:                    
                   116:                    LBA = ( C*HpC + H ) * SpH + S-1         : Logical Block Address
                   117:                    C = LBA/( HpC * SpH )                           : Cylinder Number
                   118:                    H = (LBA/SpH) mod HpC                           : Head Number
                   119:                    S = (LBA mod SpH)+1                                     : Sector Number
                   120:                                                                            HpC     : Heads per Cylinder
                   121:                                                                            SpH     : Sectors per Head(Track)
                   122:    
                   123:    
                   124:            Drive/Head Register
                   125:                    b7   b6   b5   b4   b3   b2   b1   b0
                   126:                     1   LBA   1   DRV  --- HEAD/LBA ----
                   127:                                    LBA = 1..LBA mode, 0..CHS mode
                   128:    
                   129:            Status And Alternate Status
                   130:                    b7   b6   b5   b4   b3   b2   b1   b0
                   131:                    BSY  DRDY DWF  DSC  DRQ  CORR IDX  ERR
                   132:    
                   133:                            IDX = ANSI ATA Standard
                   134:                            DWF = Drive Write Failute
                   135:    
                   136:            Device Control Register
                   137:                    b7   b6   b5   b4   b3   b2   b1   b0
                   138:                    --   --   --   --   --  SRST nlEN  --
                   139:    
                   140:                            nlEN = I/O interface mode only, negated unless enable
                   141:                            SRST = Software Reset Bit
                   142:    
                   143:            Drive Address Register
                   144:                    b7   b6   b5   b4   b3   b2   b1   b0
                   145:                    --  nWTG nHS3 nHS2 nHS1 nHS0 nDS1 nDS0
                   146:    
                   147:                            nWTG = 0... While a write operation is in progress.
                   148:    
                   149:    
                   150:    *************************************************************************/
                   151:    
                   152:    /************************************************************************
                   153:            DISK Data structure
                   154:    
                   155:                    offset  size            description
                   156:                    000h    446                     Boot code
                   157:                    1BEh    16                      Partition Entry
                   158:                    1CEh    16                      Partition Entry
                   159:                    1DEh    16                      Partition Entry
                   160:                    1EEh    16                      Partition Entry
                   161:                    1FEh    2                       Signature 0x55AA
                   162:    
                   163:    
                   164:            Paritition Entry
                   165:    
                   166:                    offset  size            description
                   167:                    00h             1                       X86 default boot parition
                   168:                                                            00h=Not Default boot partition
                   169:                                                            80h = Default boot partition
                   170:                    01h             1                       StartHead Zero-based head number
                   171:                    02h             1                       Start Sector bits0...5 = one-based sector number
                   172:                                                                                     bits6...7 = zero based cylinder number
                   173:                    03h             1                       Start Cylinder zero-based cylinder number
                   174:                    04h             1                       Partition type
                   175:                                                                    00h:Unknown or delted if num sector is zero
                   176:                                                                    01h:MS-DOS 12 bit BPB/FAT < 16MB
                   177:                                                                    04h:MS-DOS 16 bit BPB/FAT < 32MB
                   178:                                                                    05h:Extended MS-DOS Partition
                   179:                                                                    06h:MS-DOS 16 bit BPB/FAT >= 32MB
                   180:                    05h             1                       End Head Zero-based head number
                   181:                    06h             1                       End Sector   bits0...5 = one-based sector number
                   182:                                                                                             6...7 = zero-based cylinder number
                   183:                    07h             1                       End Cylinder zero-based cylinder number
                   184:                    08h             4                       Start Sector(relative to beginning of media or extended MS-DOS Partition )
                   185:                    0Ch             4                       NumSectors
                   186:    
                   187:    
                   188:            Cluster Code in FAT
                   189:                    (0)000h                         Available or unallocated cluster
                   190:                    (0)001h                         Reserved, do not use this
                   191:                    (0)002h..(F)FF6h        Next cluster 
                   192:                    (F)FF7h                         Bad Cluster
                   193:                    (F)FF8h..(F)FFFh        last cluster
                   194:    
                   195:            BPB Record
                   196:    
                   197:                    offset  size            description
                   198:                    000h    3                       JMP Instruction
                   199:                    003h    8                       OEM Name and version
                   200:                    00Bh    25                      BIOS Parameter Block
                   201:                    024h    1                       Drive Number (00h=Floppy, 80h=Fixed)
                   202:                    025h    1                       Reserved 
                   203:                    026h    1                       ExtBootSignature 0x29
                   204:                    027h    4                       Volume ID or Serial Number
                   205:                    02Bh    11                      Volume Label  Ascii Characters(Padded Space)
                   206:                    036h    8                       File Sys Type (Padded Space)
                   207:                                                                    'FAT12   '              12bit FAT File Allocation
                   208:                                                                    'FAT16   '              16bit FAT File Allocation
                   209:                    03Eh    448                     Boot Code
                   210:                    1FEh    2                       Signature 0x55AA
                   211:    
                   212:    
                   213:            BIOS Parameter Block
                   214:    
                   215:                    offset  size            description
                   216:                    000h    2                       Bytes Per Sector
                   217:                    002h    1                       Sectors Per Cluster
                   218:                    003h    2                       Reserved Sectors
                   219:                    005h    1                       NumFATs
                   220:                    006h    2                       RootDirEntries
                   221:                    008h    2                       TotalSectors
                   222:                                                                    0 is Huge Total Sectors field
                   223:                    00Ah    1                       MediaID Byte
                   224:                                                                    0F0h    Various types of media
                   225:                                                                    0F8h    Hard Disk
                   226:                                                                    0F9h    720K 3.5' or 1.2M 5.25'
                   227:                                                                    0FAh    320K 5.25'
                   228:                                                                    0FBh    640K 3.5'
                   229:                                                                    0FCh    180K 5.25'
                   230:                                                                    0FDh    360K 5.25'
                   231:                                                                    0FEh    160K 5.25'
                   232:                                                                    0FFh    320K 5.25'
                   233:                    00Bh    2                       NumFATSectors
                   234:                    00Dh    2                       Sectors per Track
                   235:                    00Fh    2                       NumHeads
                   236:                    011h    4                       Hidden Sectors
                   237:                    015h    4                       Huge Sectors 
                   238:    
                   239:    ***************************************************************************/
