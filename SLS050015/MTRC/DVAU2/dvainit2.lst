    000010 38D0                   MOV.B       R0L,@16777168:8
                    97:    
                    98:                    PA.DDR = 0xFF;          /* PA b7=A20, b6= , b5= , b4= , b3=DTR1, b2=RTS1, b1=DTR0, b0=RTS0 */
    000012 F8FF                   MOV.B       #-1:8,R0L
    000014 38D1                   MOV.B       R0L,@16777169:8
                    99:    
